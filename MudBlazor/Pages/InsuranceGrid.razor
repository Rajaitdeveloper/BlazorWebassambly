@page "/insurance"
@using System.Globalization

<div class="insurance-dashboard">

    <div class="insurance-toolbar">
        <div>
            <div class="insurance-title">Insurance Policies</div>
            <div class="insurance-subtitle">Manage policy details</div>
        </div>

        <button class="btn btn-primary insurance-add-btn">
            <i class="fa-solid fa-plus me-2"></i>Add Policy
        </button>
    </div>

    <div class="insurance-card">

        <div class="insurance-filters">

            <input class="form-control insurance-search"
                   placeholder="Search policy, customer, plan"
                   @bind="SearchText"
                   @bind:event="oninput" />

            <select class="form-select insurance-select" @bind="SelectedStatus">
                <option value="">All Status</option>
                <option>Active</option>
                <option>Pending</option>
                <option>Expired</option>
                <option>Cancelled</option>
            </select>

            <select class="form-select insurance-select" @bind="SelectedPlan">
                <option value="">All Plans</option>
                @foreach (var p in Policies.Select(x => x.Plan).Distinct())
                {
                    <option>@p</option>
                }
            </select>

            <button class="btn btn-outline-secondary" @onclick="ClearFilters">
                Reset
            </button>

        </div>

        <div class="insurance-table-container">

            <table class="table insurance-table">
                <thead>
                    <tr>
                        <th>
                            <button class="sort-btn"
                                    @onclick="() => SortBy(nameof(InsurancePolicy.PolicyNumber))">
                                Policy
                                @SortIcon(nameof(InsurancePolicy.PolicyNumber))
                            </button>
                        </th>

                        <th>
                            <button class="sort-btn"
                                    @onclick="() => SortBy(nameof(InsurancePolicy.CustomerName))">
                                Customer
                                @SortIcon(nameof(InsurancePolicy.CustomerName))
                            </button>
                        </th>

                        <th>
                            <button class="sort-btn"
                                    @onclick="() => SortBy(nameof(InsurancePolicy.Plan))">
                                Plan
                                @SortIcon(nameof(InsurancePolicy.Plan))
                            </button>
                        </th>

                        <th>
                            <button class="sort-btn"
                                    @onclick="() => SortBy(nameof(InsurancePolicy.Premium))">
                                Premium
                                @SortIcon(nameof(InsurancePolicy.Premium))
                            </button>
                        </th>

                        <th>
                            <button class="sort-btn"
                                    @onclick="() => SortBy(nameof(InsurancePolicy.Status))">
                                Status
                                @SortIcon(nameof(InsurancePolicy.Status))
                            </button>
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @if (PagedPolicies.Any())
                    {
                        @foreach (var item in PagedPolicies)
                        {
                            <tr>
                                <td>@item.PolicyNumber</td>

                                <td>
                                    <div class="customer-name">@item.CustomerName</div>
                                    <div class="customer-email">@item.Email</div>
                                </td>

                                <td>@item.Plan</td>

                                <td>@item.Premium.ToString("C", UsCulture)</td>

                                <td>
                                    <span class="status-badge @item.Status.ToLowerInvariant()">
                                        @item.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4">
                                No records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

        <div class="insurance-pagination">

            <div>
                Showing @StartItem - @EndItem of @FilteredPolicies.Count()
            </div>

            <div class="pagination-controls">

                <select class="form-select page-size-select" @bind="PageSize">
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="20">20</option>
                </select>

                <button class="btn btn-outline-secondary"
                        @onclick="PreviousPage"
                        disabled="@(CurrentPage == 1)">
                    Prev
                </button>

                <span class="page-indicator">
                    Page @CurrentPage / @TotalPages
                </span>

                <button class="btn btn-outline-secondary"
                        @onclick="NextPage"
                        disabled="@(CurrentPage == TotalPages || TotalPages == 0)">
                    Next
                </button>

            </div>

        </div>

    </div>

</div>

<style>
    /* ---------------- LAYOUT ---------------- */

    .insurance-dashboard {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .insurance-card {
        border: 1px solid var(--bs-border-color);
        border-radius: 14px;
        overflow: hidden;
        background: var(--bs-body-bg);
    }

    /* ---------------- TOOLBAR ---------------- */

    .insurance-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .insurance-title {
        font-size: 1.3rem;
        font-weight: 700;
    }

    .insurance-subtitle {
        color: var(--bs-secondary-color);
    }

    .insurance-add-btn {
        border-radius: 12px;
    }

    /* ---------------- FILTERS ---------------- */

    .insurance-filters {
        display: flex;
        gap: 12px;
        padding: 16px;
        border-bottom: 1px solid var(--bs-border-color);
        flex-wrap: wrap;
    }

    .insurance-search {
        min-width: 260px;
        flex: 1 1 260px;
    }

    .insurance-select {
        width: 160px;
    }

    /* ---------------- TABLE ---------------- */

    .insurance-table {
        margin: 0;
    }

    .insurance-table tbody tr:hover {
        background: rgba(var(--bs-primary-rgb), .05);
    }

    .insurance-table td {
        padding: 14px 18px;
        border-bottom: 1px solid var(--bs-border-color);
        vertical-align: middle;
    }

    .customer-name {
        font-weight: 600;
    }

    .customer-email {
        font-size: .875rem;
        color: var(--bs-secondary-color);
    }

    /* ---------------- COLUMN HEADER ---------------- */

    .insurance-table thead th {
        background: var(--bs-tertiary-bg);
        position: sticky;
        top: 0;
        z-index: 2;
        padding: 14px 18px;
        border-bottom: 1px solid var(--bs-border-color);
        font-size: .85rem;
    }

    .sort-btn {
        background: none;
        border: none;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        gap: 6px;
        align-items: center;
        padding: 0;
    }

    /* ---------------- SCROLL ---------------- */

    .insurance-table-container {
        max-height: 420px;
        overflow: auto;
    }

    .insurance-table-container::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    .insurance-table-container::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, .25);
        border-radius: 10px;
    }

    /* ---------------- PAGINATION ---------------- */

    .insurance-pagination {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 18px;
        border-top: 1px solid var(--bs-border-color);
        gap: 12px;
        flex-wrap: wrap;
    }

    .pagination-controls {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    .page-size-select {
        width: 80px;
    }

    .page-indicator {
        font-weight: 600;
    }

    /* ---------------- STATUS BADGES ---------------- */

    .status-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: .8rem;
        font-weight: 700;
        display: inline-block;
    }

    .status-badge.active {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-badge.expired {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-badge.cancelled {
        background: #e2e8f0;
        color: #475569;
    }

    /* ---------------- RESPONSIVE ---------------- */

    @@media (max-width: 768px) {
        .insurance-filters {
            flex-direction: column;
        }

        .insurance-search,
        .insurance-select {
            width: 100%;
        }

        .insurance-pagination {
            flex-direction: column;
            align-items: stretch;
        }

        .pagination-controls {
            justify-content: space-between;
        }
    }
</style>

@code {
    private static readonly CultureInfo UsCulture = CultureInfo.GetCultureInfo("en-US");

    private string SearchText = "";
    private string SelectedStatus = "";
    private string SelectedPlan = "";

    private string SortColumn = nameof(InsurancePolicy.PolicyNumber);
    private bool SortAscending = true;

    private int _pageSize = 5;
    private int PageSize
    {
        get => _pageSize;
        set
        {
            _pageSize = value;
            CurrentPage = 1;
        }
    }

    private int CurrentPage = 1;

    private List<InsurancePolicy> Policies = new()
    {
        new() { PolicyNumber = "INS1001", CustomerName = "John Carter", Email = "john@email.com", Plan = "Gold", Premium = 420, Status = "Active" },
        new() { PolicyNumber = "INS1002", CustomerName = "Mary Smith", Email = "mary@email.com", Plan = "Silver", Premium = 310, Status = "Pending" },
        new() { PolicyNumber = "INS1003", CustomerName = "Robert King", Email = "robert@email.com", Plan = "Gold", Premium = 650, Status = "Active" },
        new() { PolicyNumber = "INS1004", CustomerName = "Jennifer Lopez", Email = "jen@email.com", Plan = "Basic", Premium = 210, Status = "Expired" },
        new() { PolicyNumber = "INS1005", CustomerName = "David Lee", Email = "david@email.com", Plan = "Gold", Premium = 430, Status = "Active" },
        new() { PolicyNumber = "INS1006", CustomerName = "Sophia Brown", Email = "sophia@email.com", Plan = "Silver", Premium = 295, Status = "Pending" }
    };

    private IEnumerable<InsurancePolicy> FilteredPolicies
    {
        get
        {
            var query = Policies.Where(p =>
                (string.IsNullOrWhiteSpace(SearchText) ||
                 p.PolicyNumber.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                 p.CustomerName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                 p.Plan.Contains(SearchText, StringComparison.OrdinalIgnoreCase))
                && (string.IsNullOrWhiteSpace(SelectedStatus) || p.Status == SelectedStatus)
                && (string.IsNullOrWhiteSpace(SelectedPlan) || p.Plan == SelectedPlan));

            var count = query.Count();
            var totalPages = Math.Max(1, (int)Math.Ceiling(count / (double)PageSize));

            if (CurrentPage > totalPages)
                CurrentPage = totalPages;

            return query;
        }
    }

    private IEnumerable<InsurancePolicy> SortedPolicies =>
        SortColumn switch
        {
            nameof(InsurancePolicy.CustomerName) => SortAscending
                ? FilteredPolicies.OrderBy(x => x.CustomerName)
                : FilteredPolicies.OrderByDescending(x => x.CustomerName),

            nameof(InsurancePolicy.Plan) => SortAscending
                ? FilteredPolicies.OrderBy(x => x.Plan)
                : FilteredPolicies.OrderByDescending(x => x.Plan),

            nameof(InsurancePolicy.Premium) => SortAscending
                ? FilteredPolicies.OrderBy(x => x.Premium)
                : FilteredPolicies.OrderByDescending(x => x.Premium),

            nameof(InsurancePolicy.Status) => SortAscending
                ? FilteredPolicies.OrderBy(x => x.Status)
                : FilteredPolicies.OrderByDescending(x => x.Status),

            _ => SortAscending
                ? FilteredPolicies.OrderBy(x => x.PolicyNumber)
                : FilteredPolicies.OrderByDescending(x => x.PolicyNumber)
        };

    private IEnumerable<InsurancePolicy> PagedPolicies =>
        SortedPolicies.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(FilteredPolicies.Count() / (double)PageSize));

    private int StartItem =>
        FilteredPolicies.Any() ? ((CurrentPage - 1) * PageSize) + 1 : 0;

    private int EndItem =>
        Math.Min(CurrentPage * PageSize, FilteredPolicies.Count());

    private void SortBy(string column)
    {
        if (SortColumn == column)
            SortAscending = !SortAscending;
        else
        {
            SortColumn = column;
            SortAscending = true;
        }

        CurrentPage = 1;
    }

    private void PreviousPage()
    {
        if (CurrentPage > 1)
            CurrentPage--;
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages)
            CurrentPage++;
    }

    private void ClearFilters()
    {
        SearchText = "";
        SelectedStatus = "";
        SelectedPlan = "";
        CurrentPage = 1;
        SortColumn = nameof(InsurancePolicy.PolicyNumber);
        SortAscending = true;
    }

    private RenderFragment SortIcon(string column) => builder =>
    {
        var icon = SortColumn != column
            ? "fa-sort"
            : SortAscending
                ? "fa-sort-up"
                : "fa-sort-down";

        builder.OpenElement(0, "i");
        builder.AddAttribute(1, "class", $"fa-solid {icon}");
        builder.CloseElement();
    };

    public class InsurancePolicy
    {
        public string PolicyNumber { get; set; } = string.Empty;
        public string CustomerName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Plan { get; set; } = string.Empty;
        public decimal Premium { get; set; }
        public string Status { get; set; } = string.Empty;
    }
}
