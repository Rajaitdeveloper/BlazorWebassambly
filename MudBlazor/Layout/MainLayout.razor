@inherits LayoutComponentBase
@using Microsoft.JSInterop
@inject IJSRuntime JS

<div class="app-shell">

    <aside class="@($"sidebar {(_collapsed ? "sidebar-collapsed" : "")}")">

        <div class="sidebar-header">
            <div class="logo">
                <i class="fa-solid fa-stethoscope"></i>
            </div>

            <div class="brand-text">
                <div class="fw-semibold">Blazor Web Assambly</div>
                <div class="small text-body-secondary">Test Portal</div>
            </div>
        </div>

        <hr class="my-2" />

        <nav class="nav flex-column px-2">

            <NavLink href="/insurance" Match="NavLinkMatch.All" class="nav-link sidebar-link">
                <span class="icon"><i class="fa-solid fa-chart-line fa-fw"></i></span>
                <span class="text">Dashboard</span>
            </NavLink>

            <button type="button"
                    class="nav-link sidebar-link sidebar-parent-btn @( _serversExpanded ? "expanded" : "" )"
                    @onclick="ToggleServers">

                <span class="icon"><i class="fa-solid fa-server fa-fw"></i></span>
                <span class="text">Servers</span>

                <span class="expand-icon">
                    <i class="fa-solid fa-chevron-down"></i>
                </span>
            </button>

            <div class="submenu @( _serversExpanded && !_collapsed ? "submenu-open" : "" )">
                <NavLink href="/servers/database" class="nav-link sidebar-sublink">
                    <span class="icon"><i class="fa-solid fa-database fa-fw"></i></span>
                    <span class="text">Database</span>
                </NavLink>

                <NavLink href="/servers/network" class="nav-link sidebar-sublink">
                    <span class="icon"><i class="fa-solid fa-network-wired fa-fw"></i></span>
                    <span class="text">Network</span>
                </NavLink>

                <NavLink href="/servers/compute" class="nav-link sidebar-sublink">
                    <span class="icon"><i class="fa-solid fa-microchip fa-fw"></i></span>
                    <span class="text">Compute</span>
                </NavLink>
            </div>

            <NavLink href="/billing" class="nav-link sidebar-link">
                <span class="icon"><i class="fa-solid fa-credit-card fa-fw"></i></span>
                <span class="text">Billing</span>
            </NavLink>

            <NavLink href="/users" class="nav-link sidebar-link">
                <span class="icon"><i class="fa-solid fa-users fa-fw"></i></span>
                <span class="text">Users</span>
            </NavLink>

            <NavLink href="/security" class="nav-link sidebar-link">
                <span class="icon"><i class="fa-solid fa-shield-halved fa-fw"></i></span>
                <span class="text">Security</span>
            </NavLink>

        </nav>

        <div class="profile">
            <div class="avatar">R</div>

            <div class="profile-text">
                <div class="fw-semibold">User</div>
                <div class="small text-body-secondary">Administrator</div>
            </div>
        </div>

    </aside>

    <div class="main-panel">

        <header class="topbar d-flex align-items-center px-3">

            <button class="btn btn-outline-secondary btn-sm sidebar-toggle"
                    @onclick="ToggleSidebar">
                <i class="fa-solid fa-bars"></i>
            </button>

            <div class="ms-auto">
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="ToggleTheme">
                    <i class="fa-solid @( _isDark ? "fa-sun" : "fa-moon")"></i>
                </button>
            </div>

        </header>

        <main class="content">
            @Body
        </main>

    </div>

</div>

<style>
    .app-shell {
        display: flex;
        min-height: 100vh;
        background: var(--bs-body-bg);
        color: var(--bs-body-color);
    }

    .sidebar {
        width: 260px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        border-right: 1px solid var(--bs-border-color);
        background: var(--bs-tertiary-bg);
        overflow: hidden;
        transition: width .22s ease;
    }

    .sidebar-collapsed {
        width: 72px;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        min-height: 72px;
    }

    .logo {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bs-primary);
        color: #fff;
    }

    .brand-text,
    .text,
    .profile-text {
        white-space: nowrap;
        overflow: hidden;
        opacity: 1;
        max-width: 180px;
        transition: opacity .15s ease, max-width .18s ease;
    }

    .sidebar-link,
    .sidebar-parent-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        border-radius: 12px;
        color: var(--bs-body-color);
        padding: 10px 12px;
        margin-bottom: 6px;
        text-decoration: none;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
    }

    .sidebar-link:hover,
    .sidebar-parent-btn:hover {
        background: rgba(var(--bs-primary-rgb), 0.08);
        color: var(--bs-body-color);
    }

    .sidebar-link.active,
    .sidebar-sublink.active {
        background: rgba(var(--bs-primary-rgb), 0.14);
        border-left: 4px solid #c81766;
    }

    .sidebar-parent-btn.expanded {
        background: rgba(var(--bs-primary-rgb), 0.08);
    }

    .icon {
        width: 24px;
        min-width: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .expand-icon {
        margin-left: auto;
        transition: transform .2s ease, opacity .2s ease;
    }

    .sidebar-parent-btn.expanded .expand-icon {
        transform: rotate(180deg);
    }

    .submenu {
        max-height: 0;
        overflow: hidden;
        transition: max-height .22s ease;
        margin-left: 10px;
    }

    .submenu-open {
        max-height: 220px;
    }

    .sidebar-sublink {
        display: flex;
        align-items: center;
        gap: 12px;
        border-radius: 10px;
        color: var(--bs-body-color);
        padding: 8px 12px;
        margin-bottom: 4px;
        text-decoration: none;
        font-size: 0.95rem;
    }

    .sidebar-sublink:hover {
        background: rgba(var(--bs-primary-rgb), 0.08);
        color: var(--bs-body-color);
    }

    .profile {
        margin-top: auto;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        border-top: 1px solid var(--bs-border-color);
    }

    .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bs-primary);
        color: #fff;
        font-weight: 600;
    }

    .main-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .topbar {
        height: 60px;
        border-bottom: 1px solid var(--bs-border-color);
        background: var(--bs-body-bg);
    }

    .sidebar-toggle {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .content {
        flex: 1;
        padding: 24px;
        background: var(--bs-body-bg);
        overflow: auto;
    }

    .sidebar-collapsed .brand-text,
    .sidebar-collapsed .text,
    .sidebar-collapsed .profile-text,
    .sidebar-collapsed .expand-icon,
    .sidebar-collapsed .submenu {
        opacity: 0;
        max-width: 0;
        pointer-events: none;
    }

    .sidebar-collapsed .sidebar-header,
    .sidebar-collapsed .profile {
        justify-content: center;
    }

    .sidebar-collapsed .sidebar-link,
    .sidebar-collapsed .sidebar-parent-btn {
        justify-content: center;
        gap: 0;
    }
</style>

@code {
    bool _collapsed = false;
    bool _isDark = true;
    bool _serversExpanded = false;

    void ToggleSidebar()
    {
        _collapsed = !_collapsed;
    }

    void ToggleServers()
    {
        if (_collapsed)
            return;

        _serversExpanded = !_serversExpanded;
    }

    async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("appTheme.toggle");
    }
}
