@* Pages/Profile/UserProfile.razor *@
@* Shows all JWT claims and the raw access token for the signed-in user.
   Useful during development to verify what Azure AD is returning.
   Remove or [Authorize(Roles="Admin")] this page before going to production. *@
@page "/profile"
@attribute [Authorize]

@inject AuthService          AuthSvc
@inject IAccessTokenProvider TokenProvider

<PageTitle>My Profile - Tindo Blazor</PageTitle>

<div class="profile-page">

    <div class="profile-header">
        <div class="profile-avatar">@_initials</div>
        <div>
            <h1 class="profile-name">@_displayName</h1>
            <p class="profile-email">@_email</p>
            @if (!string.IsNullOrWhiteSpace(_tenantId))
            {
                <span class="profile-badge">
                    <i class="fa-solid fa-building"></i> Tenant: @_tenantId
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(_objectId))
            {
                <span class="profile-badge profile-badge-teal">
                    <i class="fa-solid fa-fingerprint"></i> OID: @_objectId
                </span>
            }
        </div>
    </div>

    @* ── Roles ── *@
    @if (_roles.Count > 0)
    {
        <div class="profile-section">
            <div class="profile-section-title">
                <i class="fa-solid fa-shield-halved"></i> App Roles
            </div>
            <div class="profile-chips">
                @foreach (var role in _roles)
                {
                    <span class="profile-chip profile-chip-accent">@role</span>
                }
            </div>
        </div>
    }

    @* ── All Claims ── *@
    <div class="profile-section">
        <div class="profile-section-title">
            <i class="fa-solid fa-tags"></i> JWT Claims
            <span class="profile-count">@_claims.Count</span>
        </div>
        <div class="profile-table-wrap">
            <table class="profile-table">
                <thead>
                    <tr>
                        <th>Claim Type</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (type, value) in _claims)
                    {
                        <tr>
                            <td class="claim-type">@type</td>
                            <td class="claim-value">@value</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── Access Token ── *@
    <div class="profile-section">
        <div class="profile-section-title">
            <i class="fa-solid fa-key"></i> Access Token
            @if (_tokenExpiry.HasValue)
            {
                <span class="profile-expiry @(_tokenExpired ? "expired" : "valid")">
                    <i class="fa-solid @(_tokenExpired ? "fa-circle-xmark" : "fa-circle-check")"></i>
                    @(_tokenExpired ? "Expired" : "Valid until") @_tokenExpiry.Value.ToLocalTime().ToString("HH:mm:ss dd MMM yyyy")
                </span>
            }
        </div>

        @if (_tokenError is not null)
        {
            <div class="token-error">
                <i class="fa-solid fa-triangle-exclamation"></i>
                @_tokenError
            </div>
        }
        else if (_accessToken is not null)
        {
            <div class="token-box">
                <div class="token-actions">
                    <span class="token-hint">
                        Use as: <code>Authorization: Bearer &lt;token&gt;</code>
                    </span>
                    <button class="btn btn-ghost btn-sm" @onclick="CopyToken" title="Copy to clipboard">
                        <i class="fa-solid @(_copied ? "fa-check" : "fa-copy")"></i>
                        @(_copied ? "Copied!" : "Copy")
                    </button>
                </div>
                <pre class="token-raw">@_accessToken</pre>
            </div>

            @* Decoded JWT sections *@
            @if (_jwtPayload is not null)
            {
                <div class="profile-section-title" style="margin-top:16px">
                    <i class="fa-solid fa-code"></i> Decoded Payload
                </div>
                <pre class="token-raw token-json">@_jwtPayload</pre>
            }
        }
        else
        {
            <div class="token-error token-info">
                <i class="fa-solid fa-circle-info"></i>
                No access token available. To retrieve an access token for an API,
                add a scope to <code>DefaultAccessTokenScopes</code> in Program.cs,
                e.g. <code>api://YOUR-API-CLIENT-ID/access_as_user</code>
            </div>
        }
    </div>

    @* ── How to use in components ── *@
    <div class="profile-section">
        <div class="profile-section-title">
            <i class="fa-solid fa-book"></i> How to use in your components
        </div>
        <div class="code-tabs">
            <div class="code-tab-label">Get claims in any .razor component</div>
            <pre class="code-block">@@inject AuthService AuthSvc

&lt;AuthorizeView&gt;
    &lt;Authorized Context="auth"&gt;
        @@* Via AuthService static helpers *@@
        &lt;p&gt;Name:  @@AuthService.GetDisplayName(auth.User)&lt;/p&gt;
        &lt;p&gt;Email: @@AuthService.GetEmail(auth.User)&lt;/p&gt;
        &lt;p&gt;OID:   @@AuthService.GetObjectId(auth.User)&lt;/p&gt;

        @@* Any arbitrary claim *@@
        &lt;p&gt;Tenant: @@AuthService.GetClaim(auth.User, "tid")&lt;/p&gt;

        @@* Check a role *@@
        @@if (AuthService.HasRole(auth.User, "Admin")) { &lt;span&gt;Admin&lt;/span&gt; }
    &lt;/Authorized&gt;
&lt;/AuthorizeView&gt;</pre>

            <div class="code-tab-label" style="margin-top:16px">Get access token in a service or component</div>
            <pre class="code-block">@@inject AuthService AuthSvc

@@code {
    async Task CallApi()
    {
        // Simple string token
        var token = await AuthSvc.GetAccessTokenAsync();

        // With specific scopes
        var token2 = await AuthSvc.GetAccessTokenAsync(
            ["api://YOUR-API-CLIENT-ID/access_as_user"]);

        // Full token object (includes Expires, GrantedScopes)
        var tokenObj = await AuthSvc.GetAccessTokenObjectAsync();
        Console.WriteLine(tokenObj?.Expires);
    }
}</pre>

            <div class="code-tab-label" style="margin-top:16px">Call a protected API (auto-attaches Bearer token)</div>
            <pre class="code-block">@@inject IHttpClientFactory HttpFactory

@@code {
    async Task CallProtectedApi()
    {
        // "BlazoreApi" client is pre-configured in Program.cs
        // with AuthorizationMessageHandler — token attached automatically
        var client = HttpFactory.CreateClient("BlazoreApi");
        var data   = await client.GetFromJsonAsync&lt;MyDto&gt;("/api/endpoint");
    }
}</pre>

            <div class="code-tab-label" style="margin-top:16px">CascadingAuthenticationState — in any layout or page</div>
