@* Pages/Demo/GridDemo.razor *@
@* Demonstrates DataGrid in server-side mode.
   OnQuery fires for every search, filter, sort, page, and page-size change.
   Replace the simulated API delay with a real Http call.
*@
@page "/grid-demo"
@attribute [AllowAnonymous]

@inject HttpClient Http

<PageTitle>Grid Demo - Tindo Blazor</PageTitle>

<div style="display:flex; flex-direction:column; gap:24px;">

    <div>
        <h2 style="font-size:20px; font-weight:700; color:var(--txt); margin:0 0 4px">DataGrid — Server-Side Demo</h2>
        <p style="font-size:13px; color:var(--txt-3); margin:0">
            All search, filter, sort, pagination fire <strong>OnQuery</strong> — replace the simulated call with your API.
        </p>
    </div>

    @* ── Toast ── *@
    @if (!string.IsNullOrEmpty(_toast))
    {
        <div style="padding:12px 16px; background:var(--surface); border:1px solid var(--border);
                    border-left:4px solid var(--accent); border-radius:var(--radius);
                    font-size:13px; color:var(--txt); display:flex; align-items:center; gap:10px;">
            @_toast
            <button @onclick="@(() => _toast = string.Empty)"
                    style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--txt-3);font-size:13px;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    }

    @* ── Last query fired — shows what the API would receive ── *@
    @if (_lastQuery is not null)
    {
        <div style="background:var(--surface-2); border:1px solid var(--border); border-radius:var(--radius);
                    padding:12px 16px; font-size:12px; color:var(--txt-2); display:flex; flex-wrap:wrap; gap:10px; align-items:center;">
            <span style="font-weight:700; color:var(--txt);">Last query sent to API:</span>
            <span>Search: <code>@((string.IsNullOrWhiteSpace(_lastQuery.SearchTerm) ? "—" : _lastQuery.SearchTerm))</code></span>
            @foreach (var f in _lastQuery.Filters)
            {
                <span>@f.Key: <code>@f.Value</code></span>
            }
            <span>Sort: <code>@(_lastQuery.SortKey ?? "—") @(_lastQuery.SortKey != null ? (_lastQuery.SortAscending ? "↑" : "↓") : "")</code></span>
            <span>Page: <code>@(_lastQuery.Page + 1)</code></span>
            <span>PageSize: <code>@_lastQuery.PageSize</code></span>
            @if (_loading)
            {
                <span style="margin-left:auto; display:flex; align-items:center; gap:6px; color:var(--accent);">
                    <span style="width:14px;height:14px;border-radius:50%;border:2px solid var(--accent-faint);
                                 border-top-color:var(--accent);animation:dg-spin .7s linear infinite;display:inline-block;"></span>
                    Loading…
                </span>
            }
        </div>
    }

    @* ── DataGrid in server-side mode ── *@
    <DataGrid Columns="_columns"
              Rows="_rows"
              PageSize="5"
              ShowRowNumbers="true"
              ServerSide="true"
              TotalCount="@_totalCount"
              EnableSearchButton="true"
              EnableFilterButton="true"
              ShowScrollbar="true"
              ScrollHeight="500px"
              OnQuery="HandleQuery"
              OnView="HandleView"
              OnEdit="HandleEdit">
        <CellTemplate Context="cell">
            @if (cell.Column.Key == "status")
            {
                <span style="display:inline-flex; align-items:center; gap:5px;
                             padding:2px 10px; border-radius:20px; font-size:11px; font-weight:700;
                             background:@(cell.Value?.ToString() == "Active" ? "rgba(4,89,90,.12)" : "rgba(200,23,102,.1)");
                             color:@(cell.Value?.ToString() == "Active" ? "var(--teal)" : "var(--accent)")">
                    @cell.Value
                </span>
            }
            else if (cell.Column.Key == "role")
            {
                <span style="display:inline-flex; align-items:center; gap:5px;
                             padding:2px 10px; border-radius:20px; font-size:11px; font-weight:600;
                             background:var(--surface-2); color:var(--txt-2); border:1px solid var(--border)">
                    @cell.Value
                </span>
            }
            else
            {
                @cell.Value
            }
        </CellTemplate>
    </DataGrid>

</div>

<style>
    @@keyframes dg-spin { to { transform: rotate(360deg); } }
    code { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 1px 5px; font-size: 11px; }
</style>

