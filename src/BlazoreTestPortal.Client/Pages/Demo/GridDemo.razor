@* Pages/Demo/GridDemo.razor *@
@page "/grid-demo"
@attribute [AllowAnonymous]

<PageTitle>Grid Demo - Tindo Blazor</PageTitle>

<div style="padding: 28px 32px; display:flex; flex-direction:column; gap:24px;">

    <div>
        <h2 style="font-size:20px; font-weight:700; color:var(--txt); margin:0 0 4px">DataGrid Demo</h2>
        <p style="font-size:13px; color:var(--txt-3); margin:0">Dynamic columns, sort, filter, pagination, hidden columns, row actions.</p>
    </div>

    @if (!string.IsNullOrEmpty(_toast))
    {
        <div style="padding:12px 16px; background:var(--surface); border:1px solid var(--border);
                    border-left:4px solid var(--accent); border-radius:var(--radius);
                    font-size:13px; color:var(--txt); display:flex; align-items:center; gap:10px;">
            @_toast
            <button @onclick="@(() => _toast = string.Empty)"
                    style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--txt-3);font-size:13px;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    }

    <DataGrid Columns="_columns"
              Rows="_rows"
              PageSize="5"
              ShowRowNumbers="true"
              OnView="HandleView"
              OnEdit="HandleEdit">
        <CellTemplate Context="cell">
            @if (cell.Column.Key == "status")
            {
                <span style="display:inline-flex;align-items:center;gap:5px;
                             padding:2px 10px; border-radius:20px; font-size:11px; font-weight:700;
                             background:@(cell.Value?.ToString() == "Active" ? "rgba(4,89,90,.12)" : "rgba(200,23,102,.1)");
                             color:@(cell.Value?.ToString() == "Active" ? "var(--teal)" : "var(--accent)")">
                    @cell.Value
                </span>
            }
            else if (cell.Column.Key == "role")
            {
                <span style="display:inline-flex;align-items:center;gap:5px;
                             padding:2px 10px; border-radius:20px; font-size:11px; font-weight:600;
                             background:var(--surface-2); color:var(--txt-2);
                             border:1px solid var(--border)">
                    @cell.Value
                </span>
            }
            else
            {
                @cell.Value
            }
        </CellTemplate>
    </DataGrid>

</div>

@code {
    readonly List<DataGrid.GridColumn> _columns =
    [
        new() { Key = "id",         Label = "ID",           Hidden = true                                         },
        new() { Key = "name",       Label = "Full Name",    Width = "180px", Sortable = true,  Filterable = true  },
        new() { Key = "email",      Label = "Email",        Width = "1fr",   Sortable = true,  Filterable = true  },
        new() { Key = "department", Label = "Department",   Width = "150px", Sortable = true,  Filterable = true  },
        new() { Key = "role",       Label = "Role",         Width = "120px", Sortable = true,  Filterable = false },
        new() { Key = "status",     Label = "Status",       Width = "100px", Sortable = true,  Filterable = false },
        new() { Key = "joined",     Label = "Joined",       Width = "110px", Sortable = true,  Filterable = false },
    ];

    string _toast = string.Empty;

    void HandleView(DataGrid.RowActionContext ctx)
    {
        var id   = ctx.Get<string>("id");
        var name = ctx.Get<string>("name");
        _toast = $"👁 Viewing {name} (ID: {id})";
        StateHasChanged();
    }

    void HandleEdit(DataGrid.RowActionContext ctx)
    {
        var id   = ctx.Get<string>("id");
        var name = ctx.Get<string>("name");
        _toast = $"✏️ Editing {name} (ID: {id})";
        StateHasChanged();
    }

