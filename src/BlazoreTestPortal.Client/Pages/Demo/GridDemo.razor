            //       var sb = new StringBuilder("api/users?");
            //       if (!string.IsNullOrWhiteSpace(q.SearchTerm))
            //           sb.Append($"search={Uri.EscapeDataString(q.SearchTerm)}&");
            //       foreach (var f in q.Filters)
            //           sb.Append($"{f.Key}={Uri.EscapeDataString(f.Value)}&");
            //       if (q.SortKey != null)
            //           sb.Append($"sortBy={q.SortKey}&sortDir={( q.SortAscending ? "asc" : "desc")}&");
            //       sb.Append($"page={q.Page}&pageSize={q.PageSize}");
            //       return sb.ToString();
            //   }
            // ══════════════════════════════════════════════════════════════════

            // ── SIMULATED SERVER-SIDE LOGIC (remove in production) ────────────
            await Task.Delay(400); // simulate network latency

            // Use IEnumerable (not IQueryable) so lambdas are compiled delegates
            // and null-propagating operators (?.) are allowed.
            IEnumerable<Dictionary<string, object?>> source = _seedData;

            // Apply global search
            if (!string.IsNullOrWhiteSpace(query.SearchTerm))
            {
                var q = query.SearchTerm.Trim();
                source = source.Where(r => r.Values.Any(v =>
                    v != null && v.ToString() != null &&
                    v.ToString()!.Contains(q, StringComparison.OrdinalIgnoreCase)));
            }

            // Apply column filters
            foreach (var (key, value) in query.Filters)
            {
                if (string.IsNullOrWhiteSpace(value)) continue;
                var filterKey = key;
                var filterVal = value;
                source = source.Where(r =>
                {
                    var cell = r.GetValueOrDefault(filterKey);
                    return cell != null &&
                           cell.ToString() != null &&
                           cell.ToString()!.Contains(filterVal, StringComparison.OrdinalIgnoreCase);
                });
            }

            // Apply sort
            if (!string.IsNullOrWhiteSpace(query.SortKey))
            {
                var sortKey = query.SortKey;
                source = query.SortAscending
                    ? source.OrderBy(r =>
                    {
                        var v = r.GetValueOrDefault(sortKey);
                        return v != null ? v.ToString() : string.Empty;
                    }, StringComparer.OrdinalIgnoreCase)
                    : source.OrderByDescending(r =>
                    {
                        var v = r.GetValueOrDefault(sortKey);
                        return v != null ? v.ToString() : string.Empty;
                    }, StringComparer.OrdinalIgnoreCase);
            }

            // Get total count BEFORE paging
            var allMatched = source.ToList();
            _totalCount    = allMatched.Count;

            // Apply paging
            _rows = allMatched
                .Skip(query.Page * query.PageSize)
                .Take(query.PageSize)
                .ToList();
            // ── END SIMULATED LOGIC ───────────────────────────────────────────
        }
        catch (Exception ex)
        {
            _toast = $"❌ Failed to load data: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    // ── Row action handlers ───────────────────────────────────────────────────

    Task HandleView(DataGrid.RowActionContext ctx)
    {
        var id   = ctx.Get<string>("id");
        var name = ctx.Get<string>("name");
        _toast   = $"👁 Viewing {name} (ID: {id})";
        // In production: Nav.NavigateTo($"/users/{id}") or open a modal
        return Task.CompletedTask;
    }

    Task HandleEdit(DataGrid.RowActionContext ctx)
