@* Shared/Utilities/UiRadioGroup.razor *@
@* Radio button group.
   Usage:
     <UiRadioGroup Label="Priority"
                   Width="FieldWidth.Half"
                   Options="_priorityOptions"
                   @bind-Value="_priority"
                   OnValueChanged="v => _priority = v"
                   Layout="RadioLayout.Horizontal" />
*@

<div class="urg-wrap @WidthClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="urg-label">
            @Label
            @if (Required) { <span class="urg-required">*</span> }
        </label>
    }
    <div class="urg-options @(Layout == RadioLayout.Horizontal ? "urg-horizontal" : "urg-vertical")">
        @foreach (var opt in Options)
        {
            var optId = $"{_name}-{opt.Value}";
            <label class="urg-option @(Value == opt.Value ? "urg-checked" : "") @(Disabled || opt.Disabled ? "urg-opt-disabled" : "")">
                <input id="@optId"
                       type="radio"
                       name="@_name"
                       value="@opt.Value"
                       checked="@(Value == opt.Value)"
                       disabled="@(Disabled || opt.Disabled)"
                       @onchange="() => OnChange(opt.Value)" />
                <span class="urg-radio"></span>
                <span class="urg-option-label">@opt.Label</span>
                @if (!string.IsNullOrEmpty(opt.Description))
                {
                    <span class="urg-option-desc">@opt.Description</span>
                }
            </label>
        }
    </div>
    @if (HasError && !string.IsNullOrEmpty(ErrorMessage))
    {
        <span class="urg-error-msg"><i class="fa-solid fa-circle-exclamation"></i> @ErrorMessage</span>
    }
    @if (!string.IsNullOrEmpty(HelpText) && !HasError)
    {
        <span class="urg-help">@HelpText</span>
    }
</div>

@code {
    public enum FieldWidth   { Full, Half, Third }
    public enum RadioLayout  { Horizontal, Vertical }

    public sealed class RadioOption
    {
        public required string Value       { get; init; }
        public required string Label       { get; init; }
        public          string Description { get; init; } = string.Empty;
        public          bool   Disabled    { get; init; } = false;
    }

    [Parameter] public string       Label        { get; set; } = string.Empty;
    [Parameter] public string       Value        { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged   { get; set; }
    [Parameter] public EventCallback<string> OnValueChanged { get; set; }
    [Parameter] public FieldWidth   Width        { get; set; } = FieldWidth.Full;
    [Parameter] public RadioLayout  Layout       { get; set; } = RadioLayout.Horizontal;
    [Parameter] public List<RadioOption> Options { get; set; } = [];
    [Parameter] public bool         Required     { get; set; } = false;
    [Parameter] public bool         Disabled     { get; set; } = false;
    [Parameter] public bool         HasError     { get; set; } = false;
    [Parameter] public string       ErrorMessage { get; set; } = string.Empty;
    [Parameter] public string       HelpText     { get; set; } = string.Empty;

    readonly string _name = $"urg-{Guid.NewGuid():N}";

    string WidthClass => Width switch
    {
        FieldWidth.Half  => "urg-half",
        FieldWidth.Third => "urg-third",
        _                => "urg-full",
    };

    async Task OnChange(string value)
    {
        await ValueChanged.InvokeAsync(value);
        await OnValueChanged.InvokeAsync(value);
    }
}

<style>
    .urg-wrap  { display: flex; flex-direction: column; gap: 6px; }
    .urg-full  { width: 100%; }
    .urg-half  { width: calc(50% - 8px); }
    .urg-third { width: calc(33.333% - 11px); }

    .urg-label    { font-size: 12.5px; font-weight: 600; color: var(--txt-2, #475569); letter-spacing: .1px; }
    .urg-required { color: var(--accent, #c81766); margin-left: 2px; }

    .urg-options { display: flex; flex-wrap: wrap; gap: 8px; }
    .urg-horizontal { flex-direction: row; }
    .urg-vertical   { flex-direction: column; gap: 6px; }

    .urg-option {
        display: flex; align-items: flex-start; gap: 10px;
        padding: 9px 14px; border-radius: var(--radius, 8px);
        border: 1.5px solid var(--border, #e2e8f0);
        background: var(--surface, #fff);
        cursor: pointer; transition: border-color .15s, background .15s;
        font-size: 13.5px; color: var(--txt, #1e293b);
        flex-direction: column; gap: 2px;
        position: relative; padding-left: 38px;
    }
    .urg-option input[type="radio"] { display: none; }

    .urg-option:hover:not(.urg-opt-disabled) {
        border-color: var(--accent, #c81766);
        background: var(--accent-faint, rgba(200,23,102,.05));
    }
    .urg-option.urg-checked {
        border-color: var(--accent, #c81766);
        background: var(--accent-faint, rgba(200,23,102,.07));
    }
    .urg-option.urg-opt-disabled { opacity: .5; cursor: not-allowed; }

    .urg-radio {
        position: absolute; left: 12px; top: 11px;
        width: 16px; height: 16px; border-radius: 50%;
        border: 2px solid var(--border-2, #cbd5e1);
        background: var(--surface, #fff);
        flex-shrink: 0; transition: border-color .15s;
        display: flex; align-items: center; justify-content: center;
    }
    .urg-checked .urg-radio {
        border-color: var(--accent, #c81766);
    }
    .urg-checked .urg-radio::after {
        content: ''; width: 7px; height: 7px; border-radius: 50%;
        background: var(--accent, #c81766);
    }

    .urg-option-label { font-size: 13.5px; font-weight: 500; color: var(--txt, #1e293b); }
    .urg-option-desc  { font-size: 11.5px; color: var(--txt-3, #94a3b8); line-height: 1.4; }

    .urg-error-msg { font-size: 11.5px; color: #e11d48; display: flex; align-items: center; gap: 4px; }
    .urg-help      { font-size: 11.5px; color: var(--txt-3, #94a3b8); line-height: 1.4; }

    @@media (max-width: 640px) {
        .urg-half, .urg-third { width: 100%; }
        .urg-horizontal { flex-direction: column; }
    }
</style>
