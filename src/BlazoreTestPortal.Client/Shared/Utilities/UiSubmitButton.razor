@* Shared/Utilities/UiSubmitButton.razor *@
@* Submit button with loading state.
   Usage:
     <UiSubmitButton Label="Save Changes"
                     Loading="@_saving"
                     OnClick="HandleSubmit"
                     Icon="fa-solid fa-floppy-disk" />
*@

<button type="@(IsSubmit ? "submit" : "button")"
        class="usb-btn usb-@Variant.ToString().ToLower() @(FullWidth ? "usb-full" : "") @(Loading ? "usb-loading" : "")"
        disabled="@(Disabled || Loading)"
        @onclick="OnClick">
    @if (Loading)
    {
        <span class="usb-spinner"></span>
        <span>@(LoadingLabel ?? Label)</span>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Icon))
        {
            <i class="@Icon"></i>
        }
        <span>@Label</span>
    }
</button>

@code {
    public enum ButtonVariant { Primary, Teal, Danger, Ghost, Outline }

    [Parameter] public string          Label        { get; set; } = "Submit";
    [Parameter] public string?         LoadingLabel { get; set; }
    [Parameter] public string          Icon         { get; set; } = string.Empty;
    [Parameter] public ButtonVariant   Variant      { get; set; } = ButtonVariant.Primary;
    [Parameter] public bool            Loading      { get; set; } = false;
    [Parameter] public bool            Disabled     { get; set; } = false;
    [Parameter] public bool            FullWidth    { get; set; } = false;
    [Parameter] public bool            IsSubmit     { get; set; } = true;
    [Parameter] public EventCallback   OnClick      { get; set; }
}

<style>
    .usb-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 9px 20px; border-radius: var(--radius, 8px);
        font-size: 13.5px; font-weight: 700; cursor: pointer;
        font-family: var(--font, 'Plus Jakarta Sans', system-ui, sans-serif);
        border: 1.5px solid transparent;
        transition: background .15s, border-color .15s, opacity .15s, transform .1s;
        white-space: nowrap;
    }
    .usb-btn:active:not(:disabled) { transform: scale(.98); }
    .usb-btn:disabled              { opacity: .55; cursor: not-allowed; }
    .usb-full                      { width: 100%; justify-content: center; }

    /* Variants */
    .usb-primary { background: var(--accent, #c81766); color: #fff; border-color: var(--accent, #c81766); }
    .usb-primary:hover:not(:disabled) { background: var(--accent-hover, #a81257); border-color: var(--accent-hover, #a81257); }

    .usb-teal { background: var(--teal, #04595a); color: #fff; border-color: var(--teal, #04595a); }
    .usb-teal:hover:not(:disabled) { background: var(--teal-hover, #034445); border-color: var(--teal-hover, #034445); }

    .usb-danger { background: #e11d48; color: #fff; border-color: #e11d48; }
    .usb-danger:hover:not(:disabled) { background: #be123c; border-color: #be123c; }

    .usb-ghost { background: transparent; color: var(--txt-2, #475569); border-color: var(--border, #e2e8f0); }
    .usb-ghost:hover:not(:disabled) { background: var(--surface-2, #f7f9fc); border-color: var(--border-2, #cbd5e1); color: var(--txt, #1e293b); }

    .usb-outline { background: transparent; color: var(--accent, #c81766); border-color: var(--accent, #c81766); }
    .usb-outline:hover:not(:disabled) { background: var(--accent-faint, rgba(200,23,102,.08)); }

    /* Loading spinner */
    .usb-spinner {
        width: 14px; height: 14px; border-radius: 50%;
        border: 2px solid rgba(255,255,255,.35);
        border-top-color: #fff;
        animation: usb-spin .7s linear infinite;
        flex-shrink: 0;
    }
    .usb-ghost .usb-spinner,
    .usb-outline .usb-spinner {
        border-color: rgba(0,0,0,.15);
        border-top-color: var(--accent, #c81766);
    }
    @@keyframes usb-spin { to { transform: rotate(360deg); } }
</style>
