@* Shared/Utilities/UiDropdown.razor *@
@* Single-select dropdown.
   Usage:
     <UiDropdown Label="Department"
                 Width="FieldWidth.Half"
                 Options="_deptOptions"
                 @bind-Value="_dept"
                 OnValueChanged="v => _dept = v" />

   Options = List<DropdownOption> with Value + Label properties.
*@

<div class="udd-wrap @WidthClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="udd-label" for="@_id">
            @Label
            @if (Required) { <span class="udd-required">*</span> }
        </label>
    }
    <div class="udd-select-wrap @(HasError ? "udd-has-error" : "") @(Disabled ? "udd-disabled" : "")">
        <select id="@_id"
                class="udd-select"
                value="@Value"
                disabled="@Disabled"
                @onchange="OnChange">
            @if (!string.IsNullOrEmpty(Placeholder))
            {
                <option value="">@Placeholder</option>
            }
            @foreach (var opt in Options)
            {
                <option value="@opt.Value" selected="@(opt.Value == Value)">@opt.Label</option>
            }
        </select>
        <span class="udd-arrow"><i class="fa-solid fa-chevron-down"></i></span>
    </div>
    @if (HasError && !string.IsNullOrEmpty(ErrorMessage))
    {
        <span class="udd-error-msg"><i class="fa-solid fa-circle-exclamation"></i> @ErrorMessage</span>
    }
    @if (!string.IsNullOrEmpty(HelpText) && !HasError)
    {
        <span class="udd-help">@HelpText</span>
    }
</div>

@code {
    public enum FieldWidth { Full, Half, Third }

    public sealed class DropdownOption
    {
        public required string Value { get; init; }
        public required string Label { get; init; }
    }

    [Parameter] public string       Label        { get; set; } = string.Empty;
    [Parameter] public string       Placeholder  { get; set; } = "Select…";
    [Parameter] public string       Value        { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged   { get; set; }
    [Parameter] public EventCallback<string> OnValueChanged { get; set; }
    [Parameter] public FieldWidth   Width        { get; set; } = FieldWidth.Full;
    [Parameter] public List<DropdownOption> Options { get; set; } = [];
    [Parameter] public bool         Required     { get; set; } = false;
    [Parameter] public bool         Disabled     { get; set; } = false;
    [Parameter] public bool         HasError     { get; set; } = false;
    [Parameter] public string       ErrorMessage { get; set; } = string.Empty;
    [Parameter] public string       HelpText     { get; set; } = string.Empty;

    readonly string _id = $"udd-{Guid.NewGuid():N}";

    string WidthClass => Width switch
    {
        FieldWidth.Half  => "udd-half",
        FieldWidth.Third => "udd-third",
        _                => "udd-full",
    };

    async Task OnChange(ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? string.Empty;
        await ValueChanged.InvokeAsync(v);
        await OnValueChanged.InvokeAsync(v);
    }
}

<style>
    .udd-wrap  { display: flex; flex-direction: column; gap: 5px; }
    .udd-full  { width: 100%; }
    .udd-half  { width: calc(50% - 8px); }
    .udd-third { width: calc(33.333% - 11px); }

    .udd-label    { font-size: 12.5px; font-weight: 600; color: var(--txt-2, #475569); letter-spacing: .1px; }
    .udd-required { color: var(--accent, #c81766); margin-left: 2px; }

    .udd-select-wrap {
        position: relative; display: flex; align-items: center;
        border: 1.5px solid var(--border, #e2e8f0);
        border-radius: var(--radius, 8px);
        background: var(--surface, #fff);
        transition: border-color .15s, box-shadow .15s;
    }
    .udd-select-wrap:focus-within {
        border-color: var(--accent, #c81766);
        box-shadow: 0 0 0 3px var(--accent-faint, rgba(200,23,102,.12));
    }
    .udd-select-wrap.udd-has-error {
        border-color: #e11d48;
        box-shadow: 0 0 0 3px rgba(225,29,72,.10);
    }
    .udd-select-wrap.udd-disabled { opacity: .55; pointer-events: none; }

    .udd-select {
        width: 100%; padding: 9px 36px 9px 12px;
        border: none; outline: none; background: transparent;
        font-size: 13.5px; color: var(--txt, #1e293b);
        font-family: var(--font, 'Plus Jakarta Sans', system-ui, sans-serif);
        appearance: none; cursor: pointer;
    }
    .udd-select:disabled { cursor: not-allowed; }

    .udd-arrow {
        position: absolute; right: 12px; pointer-events: none;
        color: var(--txt-3, #94a3b8); font-size: 11px;
        transition: transform .15s;
    }
    .udd-select-wrap:focus-within .udd-arrow { color: var(--accent, #c81766); transform: rotate(180deg); }

    .udd-error-msg { font-size: 11.5px; color: #e11d48; display: flex; align-items: center; gap: 4px; }
    .udd-help      { font-size: 11.5px; color: var(--txt-3, #94a3b8); line-height: 1.4; }

    @@media (max-width: 640px) { .udd-half, .udd-third { width: 100%; } }
</style>
