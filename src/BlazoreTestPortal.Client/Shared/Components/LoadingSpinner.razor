@* Shared/Components/LoadingSpinner.razor
   Usage: <LoadingSpinner />
          <LoadingSpinner Message="Loading…" Size="lg" /> *@

<div class="spinner-wrap spinner-@Size">
    <div class="spinner-ring"></div>
    @if (!string.IsNullOrEmpty(Message))
    {
        <span class="spinner-msg">@Message</span>
    }
</div>

@code {
    /// <summary>sm | md | lg</summary>
    [Parameter] public string  Size    { get; set; } = "md";
    [Parameter] public string? Message { get; set; }
}

<style>
    .spinner-wrap {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 12px; padding: 24px;
    }

    .spinner-ring {
        border-radius: 50%;
        border: 3px solid var(--border);
        border-top-color: var(--accent);
        animation: spin .7s linear infinite;
    }

    .spinner-sm .spinner-ring { width: 20px; height: 20px; border-width: 2px; }
    .spinner-md .spinner-ring { width: 32px; height: 32px; }
    .spinner-lg .spinner-ring { width: 48px; height: 48px; border-width: 4px; }

    .spinner-msg { font-size: 13px; color: var(--txt-2); font-weight: 500; }

    @@keyframes spin { to { transform: rotate(360deg); } }
</style>
