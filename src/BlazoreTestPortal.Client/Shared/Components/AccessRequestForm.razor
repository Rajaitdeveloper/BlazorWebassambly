@* Shared/Components/AccessRequestForm.razor *@
@* Uses global classes from forms.css — no scoped styles *@

<div class="form-card">

    <div class="form-card-header">
        <div class="form-card-icon">
            <i class="fa-solid fa-key"></i>
        </div>
        <div>
            <h2 class="form-card-title">Access Request</h2>
            <p class="form-card-subtitle">Grant or revoke user access to project scripts</p>
        </div>
    </div>

    <div class="form-card-body">

        @* ── Group 1: Project details (2 columns) ── *@
        <div class="field-group">
            <div class="field-group-header">
                <i class="fa-solid fa-folder-open field-group-icon"></i>
                <span class="field-group-title">Project Details</span>
            </div>
            <div class="field-group-body">

                <div class="form-row col-2">

                    @* 1. Project Name *@
                    <div class="field">
                        <label class="field-label" for="project">
                            Project Name <span class="field-required">*</span>
                        </label>
                        <div class="select-wrap">
                            <select id="project" class="form-select" @bind="_projectName">
                                <option value="">— Select project —</option>
                                @foreach (var p in _projects)
                                {
                                    <option value="@p">@p</option>
                                }
                            </select>
                            <i class="fa-solid fa-chevron-down select-chev"></i>
                        </div>
                    </div>

                    @* 2. Script Name *@
                    <div class="field">
                        <label class="field-label">
                            Script Name <span class="field-required">*</span>
                        </label>
                        <div class="ms-wrap @(_scriptOpen ? "open" : "")">
                            <button type="button" class="ms-trigger" @onclick="ToggleScripts">
                                <span class="ms-value">
                                    @if (_selectedScripts.Count == 0)
                                    {
                                        <span class="ms-placeholder">— Select scripts —</span>
                                    }
                                    else if (_selectedScripts.Count == _scripts.Count)
                                    {
                                        <span class="ms-tag">All selected</span>
                                    }
                                    else
                                    {
                                        @foreach (var s in _selectedScripts)
                                        {
                                            <span class="ms-tag">@s</span>
                                        }
                                    }
                                </span>
                                <i class="fa-solid fa-chevron-down ms-chev"></i>
                            </button>
                            @if (_scriptOpen)
                            {
                                <div class="ms-panel">
                                    <label class="ms-item ms-item-all">
                                        <input type="checkbox" class="cb-input"
                                               checked="@(_selectedScripts.Count == _scripts.Count)"
                                               @onchange="ToggleAll" />
                                        <span class="cb-box"></span>
                                        <span class="ms-item-label">
                                            @(_selectedScripts.Count == _scripts.Count ? "Unselect all" : "Select all")
                                        </span>
                                    </label>
                                    <div class="ms-divider"></div>
                                    @foreach (var script in _scripts)
                                    {
                                        var s = script;
                                        <label class="ms-item">
                                            <input type="checkbox" class="cb-input"
                                                   checked="@_selectedScripts.Contains(s)"
                                                   @onchange="e => ToggleScript(s, (bool)e.Value!)" />
                                            <span class="cb-box"></span>
                                            <span class="ms-item-label">@s</span>
                                        </label>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>

        @* ── Group 2: User details (3 columns) ── *@
        <div class="field-group">
            <div class="field-group-header">
                <i class="fa-solid fa-user field-group-icon"></i>
                <span class="field-group-title">User Details</span>
            </div>
            <div class="field-group-body">

                <div class="form-row col-3">

                    @* 3. User ID *@
                    <div class="field">
                        <label class="field-label" for="userid">
                            User ID <span class="field-required">*</span>
                        </label>
                        <div class="input-wrap">
                            <i class="fa-solid fa-user input-icon"></i>
                            <input id="userid" type="text"
                                   class="form-input has-clear"
                                   placeholder="Enter user ID"
                                   @bind="_userId" @bind:event="oninput" />
                            @if (!string.IsNullOrWhiteSpace(_userId))
                            {
                                <button type="button" class="input-clear"
                                        @onclick="() => _userId = string.Empty">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            }
                        </div>
                    </div>

                    @* 4. Environment (spans remaining 2 cols) *@
                    <div class="field span-2">
                        <label class="field-label">Environment Options</label>
                        <label class="toggle-row">
                            <input type="checkbox" class="toggle-input" @bind="_applyAllEnv" />
                            <span class="toggle-track">
                                <span class="toggle-thumb"></span>
                            </span>
                            <div class="toggle-text">
                                <span class="toggle-label">Apply to all lower environments</span>
                                <span class="toggle-hint">Propagates changes to DEV, SIT, and UAT</span>
                            </div>
                        </label>
                    </div>

                </div>
            </div>
        </div>

        @* ── Group 3: Access type ── *@
        <div class="field-group">
            <div class="field-group-header">
                <i class="fa-solid fa-shield-halved field-group-icon"></i>
                <span class="field-group-title">Access Type</span>
            </div>
            <div class="field-group-body">

                @* 5. Radio — horizontal layout *@
                <div class="field">
                    <label class="field-label">Select action <span class="field-required">*</span></label>
                    <div class="radio-group horizontal">
                        <label class="radio-card @(_accessType == "grant" ? "selected" : "")">
                            <input type="radio" name="access-type" value="grant"
                                   @onchange='() => _accessType = "grant"' />
                            <span class="radio-ring"></span>
                            <span class="radio-icon icon-teal"><i class="fa-solid fa-circle-check"></i></span>
                            <div class="radio-text">
                                <span class="radio-label">Grant Access</span>
                                <span class="radio-hint">Allow user to run scripts</span>
                            </div>
                        </label>
                        <label class="radio-card @(_accessType == "revoke" ? "selected" : "")">
                            <input type="radio" name="access-type" value="revoke"
                                   @onchange='() => _accessType = "revoke"' />
                            <span class="radio-ring"></span>
                            <span class="radio-icon icon-accent"><i class="fa-solid fa-ban"></i></span>
                            <div class="radio-text">
                                <span class="radio-label">Revoke Access</span>
                                <span class="radio-hint">Remove user's access</span>
                            </div>
                        </label>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <div class="form-card-footer">
        <button type="button" class="btn btn-ghost" @onclick="Reset">
            <i class="fa-solid fa-rotate-left"></i> Reset
        </button>
        <button type="button"
                class="btn @(_accessType == "revoke" ? "btn-danger" : "btn-primary")"
                disabled="@(!IsValid)"
                @onclick="Submit">
            @if (_accessType == "revoke")
            {
                <i class="fa-solid fa-ban"></i><span>Revoke Access</span>
            }
            else
            {
                <i class="fa-solid fa-circle-check"></i><span>Grant Access</span>
            }
        </button>
    </div>

</div>

@code {
    readonly List<string> _projects = ["Utilities", "Insurance"];
    readonly List<string> _scripts  = ["Billing", "Benefit"];

    string       _projectName     = string.Empty;
    List<string> _selectedScripts = [];
    string       _userId          = string.Empty;
    bool         _applyAllEnv     = false;
    string       _accessType      = "grant";
    bool         _scriptOpen      = false;

    bool IsValid =>
        !string.IsNullOrWhiteSpace(_projectName) &&
        _selectedScripts.Count > 0 &&
        !string.IsNullOrWhiteSpace(_userId) &&
        !string.IsNullOrWhiteSpace(_accessType);

    void ToggleScripts() => _scriptOpen = !_scriptOpen;

    void ToggleAll(ChangeEventArgs e)
    {
        _selectedScripts = (bool)e.Value!
            ? new List<string>(_scripts)
            : [];
    }

    void ToggleScript(string script, bool selected)
    {
        if (selected && !_selectedScripts.Contains(script))
            _selectedScripts = [.._selectedScripts, script];
        else if (!selected)
            _selectedScripts = _selectedScripts.Where(s => s != script).ToList();
    }

    void Reset()
    {
        _projectName     = string.Empty;
        _selectedScripts = [];
        _userId          = string.Empty;
        _applyAllEnv     = false;
        _accessType      = "grant";
        _scriptOpen      = false;
    }

    void Submit()
    {
        if (!IsValid) return;
        // TODO: wire to service / API call
        Reset();
    }
}
