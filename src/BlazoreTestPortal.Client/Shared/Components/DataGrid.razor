@* Shared/Components/DataGrid.razor *@
@* Self-contained reusable data grid — supports both client-side and server-side modes.
   Models (GridColumn, CellContext, RowActionContext, GridQuery, GridSortInfo) are
   defined in the @code block — no external model files needed.

   ── CLIENT-SIDE MODE (default) ───────────────────────────────────────────────
   Pass all rows up front. Grid handles filtering, sorting, paging internally.

   <DataGrid Columns="_cols" Rows="_rows" />

   ── SERVER-SIDE MODE ─────────────────────────────────────────────────────────
   Set ServerSide=true and TotalCount to the total record count from your API.
   Handle OnQuery to call your API whenever the user changes search/filter/sort/page.

   <DataGrid Columns="_cols" Rows="_rows"
             ServerSide="true"
             TotalCount="@_total"
             OnQuery="HandleQuery" />

   The OnQuery callback receives a GridQuery with:
     - SearchTerm       → global search box value
     - Filters          → Dictionary<string,string> of column key → filter value
     - SortKey          → column key being sorted (null = no sort)
     - SortAscending    → true = asc, false = desc
     - Page             → 0-based page index
     - PageSize         → rows per page

   ── CONFIGURABLE FLAGS ───────────────────────────────────────────────────────
   EnableSearchButton  → global search fires on button/Enter (not keystroke)
   EnableFilterButton  → column filters fire on button/Enter (not keystroke)
   Both default false. Set true when using server-side to avoid per-keystroke API calls.
*@

@using Microsoft.AspNetCore.Components.Web

@* ── Toolbar ── *@
<div class="dg-wrap">

    <div class="dg-toolbar">
        <div class="dg-search-wrap">
            <i class="fa-solid fa-magnifying-glass dg-search-icon"></i>
            <input class="dg-search @(EnableSearchButton ? "dg-search-has-btn" : "")"
                   type="text"
                   placeholder="Search all columns…"
                   @bind="_searchInput"
                   @bind:event="@(EnableSearchButton ? "onchange" : "oninput")"
                   @onkeydown="OnSearchKeyDown" />
            @if (!string.IsNullOrEmpty(_searchInput))
            {
                <button class="dg-search-clear @(EnableSearchButton ? "dg-search-clear-with-btn" : "")"
                        @onclick="ClearSearch" title="Clear">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            }
            @if (EnableSearchButton)
            {
                <button class="dg-search-btn" @onclick="ApplySearch" title="Search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <span>Search</span>
                </button>
            }
        </div>
        <div class="dg-toolbar-right">
            <span class="dg-count">
                @(_displayTotal) row@(_displayTotal != 1 ? "s" : "")
                @if (!ServerSide && _filtered.Count != Rows.Count)
                {
                    <span> of @Rows.Count</span>
                }
            </span>
            @if (HasActiveFilters)
            {
                <button class="dg-btn-ghost" @onclick="async () => await ClearAll()">
                    <i class="fa-solid fa-filter-circle-xmark"></i> Clear filters
                </button>
            }
        </div>
    </div>

    @* ── Column filters ── *@
    @if (VisibleColumns.Any(c => c.Filterable))
    {
        <div class="dg-filters">
            @if (ShowRowNumbers) { <div class="dg-filter-cell dg-rn-cell"></div> }
            @foreach (var col in VisibleColumns)
            {
                <div class="dg-filter-cell" style="width:@ColWidth(col); min-width:@ColMinWidth(col)">
                    @if (col.Filterable)
                    {
                        <div class="dg-col-filter-wrap">
                            <input class="dg-col-filter @(EnableFilterButton ? "dg-col-filter-has-btn" : "")"
                                   type="text"
                                   placeholder="@col.Label…"
                                   value="@GetColFilterInput(col.Key)"
                                   @oninput="e => OnColFilterInput(col.Key, e.Value?.ToString())"
                                   @onkeydown="e => OnColFilterKeyDown(e, col.Key)" />
                            @if (!string.IsNullOrEmpty(GetColFilterInput(col.Key)))
                            {
                                <button class="dg-col-filter-clear"
                                        @onclick="() => ClearColFilter(col.Key)"
                                        title="Clear">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            }
                            @if (EnableFilterButton)
                            {
                                <button class="dg-col-filter-btn"
                                        @onclick="() => ApplyColFilter(col.Key)"
                                        title="Filter">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
            @if (HasRowActions)
            {
                <div class="dg-filter-cell" style="width:auto; min-width:100px"></div>
            }
        </div>
    }

    @* ── Desktop table ── *@
    <div class="dg-table-wrap" style="@(ShowScrollbar ? $"max-height:{ScrollHeight};overflow-y:auto;overflow-x:auto;" : "overflow-x:auto;")">
        <div class="dg-table" style="grid-template-columns: @GridTemplate">

            @* Header row *@
            @if (ShowRowNumbers)
            {
                <div class="dg-th dg-rn-cell">#</div>
            }
            @foreach (var col in VisibleColumns)
            {
                <div class="dg-th @(col.Sortable ? "dg-th-sort" : "") @(SortKey == col.Key ? "dg-th-active" : "")"
                     @onclick="() => ToggleSort(col)">
                    <span class="dg-th-label">@col.Label</span>
                    @if (col.Sortable)
                    {
                        <span class="dg-sort-icon">
                            @if (SortKey == col.Key)
                            {
                                <i class="fa-solid @(SortAsc ? "fa-sort-up" : "fa-sort-down")"></i>
                            }
                            else
                            {
                                <i class="fa-solid fa-sort dg-sort-idle"></i>
                            }
                        </span>
                    }
                </div>
            }
            @if (HasRowActions)
            {
                <div class="dg-th dg-th-actions">@RowActionsLabel</div>
            }

            @* Data rows *@
            @if (!_paged.Any())
            {
                <div class="dg-empty" style="grid-column: 1 / -1">
                    <i class="fa-solid fa-inbox"></i>
                    <span>No results found</span>
                </div>
            }
            else
            {
                @foreach (var (row, idx) in _paged.Select((r, i) => (r, i)))
                {
                    @* display:contents makes dg-row invisible to the CSS grid layout
                       but keeps it as a real DOM element — so .dg-row:hover .dg-td works *@
                    <div class="dg-row @(idx % 2 == 1 ? "dg-row-alt" : "")">
                        @if (ShowRowNumbers)
                        {
                            <div class="dg-td dg-rn-cell">
                                @(_pageIndex * _pageSize + idx + 1)
                            </div>
                        }
                        @foreach (var col in VisibleColumns)
                        {
                            <div class="dg-td" data-label="@col.Label">
                                @if (CellTemplate is not null)
                                {
                                    @CellTemplate(new CellContext { Column = col, Row = row, Value = row.GetValueOrDefault(col.Key) })
                                }
                                else
                                {
                                    @row.GetValueOrDefault(col.Key)
                                }
                            </div>
                        }
                        @if (HasRowActions)
                        {
                            <div class="dg-td dg-td-actions">
                                @if (OnView.HasDelegate)
                                {
                                    <button class="dg-action-btn dg-action-view"
                                            @onclick="() => OnView.InvokeAsync(new RowActionContext { Row = row })"
                                            title="View">
                                        <i class="fa-solid fa-eye"></i>
                                        <span>View</span>
                                    </button>
                                }
                                @if (OnEdit.HasDelegate)
                                {
                                    <button class="dg-action-btn dg-action-edit"
                                            @onclick="() => OnEdit.InvokeAsync(new RowActionContext { Row = row })"
                                            title="Edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                        <span>Edit</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @* ── Mobile cards ── *@
    <div class="dg-cards">
        @if (!_paged.Any())
        {
            <div class="dg-empty dg-empty-card">
                <i class="fa-solid fa-inbox"></i>
                <span>No results found</span>
            </div>
        }
        else
        {
            @foreach (var (row, idx) in _paged.Select((r, i) => (r, i)))
            {
                <div class="dg-card">
                    @if (ShowRowNumbers)
                    {
                        <div class="dg-card-num">#@(_pageIndex * _pageSize + idx + 1)</div>
                    }
                    @foreach (var col in VisibleColumns)
                    {
                        <div class="dg-card-row">
                            <span class="dg-card-label">@col.Label</span>
                            <span class="dg-card-val">
                                @if (CellTemplate is not null)
                                {
                                    @CellTemplate(new CellContext { Column = col, Row = row, Value = row.GetValueOrDefault(col.Key) })
                                }
                                else
                                {
                                    @row.GetValueOrDefault(col.Key)
                                }
                            </span>
                        </div>
                    }
                    @if (HasRowActions)
                    {
                        <div class="dg-card-actions">
                            @if (OnView.HasDelegate)
                            {
                                <button class="dg-action-btn dg-action-view"
                                        @onclick="() => OnView.InvokeAsync(new RowActionContext { Row = row })"
                                        title="View">
                                    <i class="fa-solid fa-eye"></i>
                                    <span>View</span>
                                </button>
                            }
                            @if (OnEdit.HasDelegate)
                            {
                                <button class="dg-action-btn dg-action-edit"
                                        @onclick="() => OnEdit.InvokeAsync(new RowActionContext { Row = row })"
                                        title="Edit">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                    <span>Edit</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>

    @* ── Pagination ── *@
    @if (_totalPages > 1)
    {
        <div class="dg-pagination">
            <span class="dg-page-info">Page @(_pageIndex + 1) of @_totalPages</span>
            <div class="dg-page-btns">
                <button class="dg-page-btn" @onclick="FirstPage" disabled="@(_pageIndex == 0)" title="First">
                    <i class="fa-solid fa-angles-left"></i>
                </button>
                <button class="dg-page-btn" @onclick="PrevPage" disabled="@(_pageIndex == 0)" title="Previous">
                    <i class="fa-solid fa-angle-left"></i>
                </button>
                @foreach (var p in PageNumbers)
                {
                    <button class="dg-page-btn @(p == _pageIndex ? "dg-page-active" : "")"
                            @onclick="() => GoToPage(p)">@(p + 1)</button>
                }
                <button class="dg-page-btn" @onclick="NextPage" disabled="@(_pageIndex >= _totalPages - 1)" title="Next">
                    <i class="fa-solid fa-angle-right"></i>
                </button>
                <button class="dg-page-btn" @onclick="LastPage" disabled="@(_pageIndex >= _totalPages - 1)" title="Last">
                    <i class="fa-solid fa-angles-right"></i>
                </button>
            </div>
            <select class="dg-page-size" @bind="_pageSize" @bind:after="OnPageSizeChanged">
                <option value="5">5 / page</option>
                <option value="10">10 / page</option>
                <option value="25">25 / page</option>
                <option value="50">50 / page</option>
            </select>
        </div>
    }

</div>

@code {

    // ════════════════════════════════════════════════════════════
    //  MODELS
    // ════════════════════════════════════════════════════════════

    public sealed class GridColumn
    {
        public required string Key        { get; init; }
        public required string Label      { get; init; }
        public string?         Width      { get; init; } = "1fr";
        public string?         MinWidth   { get; init; } = "80px";
        public bool            Sortable   { get; init; } = false;
        public bool            Filterable { get; init; } = false;
        public bool            Hidden     { get; init; } = false;
    }

    public sealed class CellContext
    {
        public required GridColumn               Column { get; init; }
        public required Dictionary<string, object?> Row { get; init; }
        public          object?                  Value  { get; init; }
    }

    public sealed class RowActionContext
    {
        public required Dictionary<string, object?> Row { get; init; }
        public object? Get(string key)    => Row.GetValueOrDefault(key);
        public T?      Get<T>(string key) => Row.TryGetValue(key, out var v) && v is T t ? t : default;
    }

    /// <summary>
    /// Passed to OnQuery. Contains everything needed to build an API request.
    /// </summary>
    public sealed class GridQuery
    {
        /// <summary>Global search box value. Empty string = no global search.</summary>
        public string SearchTerm { get; init; } = string.Empty;

        /// <summary>
        /// Per-column filter values keyed by GridColumn.Key.
        /// Only contains columns that have a non-empty filter value.
        /// Example: { "name": "raja", "status": "active" }
        /// </summary>
        public Dictionary<string, string> Filters { get; init; } = [];

        /// <summary>Column key being sorted. Null = no sort applied.</summary>
        public string? SortKey { get; init; }

        /// <summary>True = ascending, false = descending.</summary>
        public bool SortAscending { get; init; } = true;

        /// <summary>0-based page index.</summary>
        public int Page { get; init; } = 0;

        /// <summary>Number of rows per page.</summary>
        public int PageSize { get; init; } = 10;
    }

    // ════════════════════════════════════════════════════════════
    //  PARAMETERS
    // ════════════════════════════════════════════════════════════

    [Parameter, EditorRequired] public List<GridColumn>                     Columns   { get; set; } = [];
    [Parameter, EditorRequired] public List<Dictionary<string, object?>>    Rows      { get; set; } = [];
    [Parameter] public int                           PageSize             { get; set; } = 10;
    [Parameter] public bool                          ShowRowNumbers        { get; set; } = false;
    [Parameter] public RenderFragment<CellContext>?  CellTemplate          { get; set; }
    [Parameter] public bool                          ShowScrollbar         { get; set; } = false;
    [Parameter] public string                        ScrollHeight          { get; set; } = "400px";

    /// <summary>
    /// Global search fires on button click or Enter when true.
    /// Fires on every keystroke when false (default, client-side).
    /// </summary>
    [Parameter] public bool                          EnableSearchButton    { get; set; } = false;

    /// <summary>
    /// Column filters fire on button click or Enter when true.
    /// Fire instantly on keystroke when false (default, client-side).
    /// </summary>
    [Parameter] public bool                          EnableFilterButton    { get; set; } = false;

    /// <summary>
    /// When true, the grid does NOT filter/sort/paginate the Rows list internally.
    /// All logic is delegated to OnQuery. You must update Rows and TotalCount from the callback.
    /// </summary>
    [Parameter] public bool                          ServerSide            { get; set; } = false;

    /// <summary>
    /// Total record count from the server — used for pagination when ServerSide=true.
    /// Ignored in client-side mode.
    /// </summary>
    [Parameter] public int                           TotalCount            { get; set; } = 0;

    /// <summary>
    /// Fires whenever the user changes search, column filters, sort, page, or page size.
    /// Only fires when ServerSide=true, EnableSearchButton=true, or EnableFilterButton=true.
    /// Receives a GridQuery — use it to build your API request.
    /// </summary>
    [Parameter] public EventCallback<GridQuery>      OnQuery               { get; set; }

    // Legacy single-purpose callbacks — still work, but OnQuery covers all cases
    [Parameter] public EventCallback<string>         OnSearch              { get; set; }

    [Parameter] public EventCallback<RowActionContext> OnView              { get; set; }
    [Parameter] public EventCallback<RowActionContext> OnEdit              { get; set; }
    [Parameter] public string                        RowActionsLabel       { get; set; } = "Actions";

    bool HasRowActions   => OnView.HasDelegate || OnEdit.HasDelegate;
    List<GridColumn> VisibleColumns { get; set; } = [];

    // ════════════════════════════════════════════════════════════
    //  INTERNAL STATE
    // ════════════════════════════════════════════════════════════

    string  _searchInput  = string.Empty;
    string  _globalSearch = string.Empty;
    string? SortKey;
    bool    SortAsc       = true;
    int     _pageIndex    = 0;
    int     _pageSize     = 10;

    // col key → pending input value (before button press)
    readonly Dictionary<string, string> _colFilterInputs  = new();
    // col key → committed filter value (used in pipeline)
    readonly Dictionary<string, string> _colFilters       = new();

    List<Dictionary<string, object?>> _filtered = [];
    List<Dictionary<string, object?>> _paged    = [];
    int _totalPages  = 1;
    int _displayTotal => ServerSide ? TotalCount : _filtered.Count;

    bool HasActiveFilters =>
        !string.IsNullOrEmpty(_searchInput) ||
        _colFilters.Any(f => !string.IsNullOrEmpty(f.Value)) ||
        _colFilterInputs.Any(f => !string.IsNullOrEmpty(f.Value));

    // ════════════════════════════════════════════════════════════
    //  LIFECYCLE
    // ════════════════════════════════════════════════════════════

    bool _initialised = false;

    protected override void OnParametersSet()
    {
        // Only set _pageSize from the parameter on first render.
        // After that, the user's selection in the dropdown owns _pageSize.
        if (!_initialised)
        {
            _pageSize    = PageSize;
            _initialised = true;
        }

        VisibleColumns = Columns.Where(col => !col.Hidden).ToList();

        if (ServerSide)
            UpdateServerSidePaging();
        else
            Recompute();
    }

    // In server-side mode, Rows is already the current page from the API
    void UpdateServerSidePaging()
    {
        _totalPages = Math.Max(1, (int)Math.Ceiling(TotalCount / (double)_pageSize));
        _paged      = Rows;
    }

    // ════════════════════════════════════════════════════════════
    //  QUERY BUILDER — builds GridQuery from current state
    // ════════════════════════════════════════════════════════════

    GridQuery BuildQuery() => new()
    {
        SearchTerm    = _globalSearch,
        Filters       = new Dictionary<string, string>(_colFilters),
        SortKey       = SortKey,
        SortAscending = SortAsc,
        Page          = _pageIndex,
        PageSize      = _pageSize,
    };

    async Task FireQuery()
    {
        if (OnQuery.HasDelegate)
            await OnQuery.InvokeAsync(BuildQuery());
    }

    // ════════════════════════════════════════════════════════════
    //  GLOBAL SEARCH
    // ════════════════════════════════════════════════════════════

    async Task ApplySearch()
    {
        _globalSearch = _searchInput;
        _pageIndex    = 0;
        if (ServerSide || OnQuery.HasDelegate)
        {
            await FireQuery();
        }
        else
        {
            Recompute();
            if (OnSearch.HasDelegate)
                await OnSearch.InvokeAsync(_globalSearch);
        }
    }

    async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (!EnableSearchButton) return;
        if (e.Key == "Enter") await ApplySearch();
    }

    async Task ClearSearch()
    {
        _searchInput  = string.Empty;
        _globalSearch = string.Empty;
        _pageIndex    = 0;
        if (ServerSide || OnQuery.HasDelegate)
            await FireQuery();
        else
        {
            Recompute();
            if (OnSearch.HasDelegate)
                await OnSearch.InvokeAsync(string.Empty);
        }
    }

    // ════════════════════════════════════════════════════════════
    //  COLUMN FILTERS
    // ════════════════════════════════════════════════════════════

    string GetColFilterInput(string key) =>
        _colFilterInputs.TryGetValue(key, out var v) ? v : string.Empty;

    void OnColFilterInput(string key, string? value)
    {
        if (string.IsNullOrEmpty(value)) _colFilterInputs.Remove(key);
        else _colFilterInputs[key] = value;

        // Instant mode — commit immediately
        if (!EnableFilterButton)
        {
            CommitColFilter(key, value);
            _pageIndex = 0;
            Recompute();
        }
    }

    async Task OnColFilterKeyDown(KeyboardEventArgs e, string key)
    {
        if (!EnableFilterButton) return;
        if (e.Key == "Enter") await ApplyColFilter(key);
    }

    async Task ApplyColFilter(string key)
    {
        var value = GetColFilterInput(key);
        CommitColFilter(key, value);
        _pageIndex = 0;

        if (ServerSide || OnQuery.HasDelegate)
            await FireQuery();
        else
            Recompute();
    }

    async Task ClearColFilter(string key)
    {
        _colFilterInputs.Remove(key);
        _colFilters.Remove(key);
        _pageIndex = 0;

        if (ServerSide || OnQuery.HasDelegate)
            await FireQuery();
        else
            Recompute();
    }

    void CommitColFilter(string key, string? value)
    {
        if (string.IsNullOrEmpty(value)) _colFilters.Remove(key);
        else _colFilters[key] = value;
    }

    // ════════════════════════════════════════════════════════════
    //  SORT
    // ════════════════════════════════════════════════════════════

    async Task ToggleSort(GridColumn col)
    {
        if (!col.Sortable) return;
        if (SortKey == col.Key) SortAsc = !SortAsc;
        else { SortKey = col.Key; SortAsc = true; }
        _pageIndex = 0;

        if (ServerSide || OnQuery.HasDelegate)
            await FireQuery();
        else
            Recompute();
    }

    // ════════════════════════════════════════════════════════════
    //  PAGINATION
    // ════════════════════════════════════════════════════════════

    async Task FirstPage() { _pageIndex = 0;              await PageChanged(); }
    async Task PrevPage()  { _pageIndex--;                 await PageChanged(); }
    async Task NextPage()  { _pageIndex++;                 await PageChanged(); }
    async Task LastPage()  { _pageIndex = _totalPages - 1; await PageChanged(); }
    async Task GoToPage(int p) { _pageIndex = p;           await PageChanged(); }

    async Task OnPageSizeChanged()
    {
        _pageIndex = 0;
        await PageChanged();
    }

    async Task PageChanged()
    {
        if (ServerSide || OnQuery.HasDelegate)
            await FireQuery();
        else
            Recompute();
    }

    // ════════════════════════════════════════════════════════════
    //  CLEAR ALL
    // ════════════════════════════════════════════════════════════

    async Task ClearAll()
    {
        _searchInput = string.Empty;
        _globalSearch = string.Empty;
        _colFilterInputs.Clear();
        _colFilters.Clear();
        SortKey    = null;
        SortAsc    = true;
        _pageIndex = 0;

        if (ServerSide || OnQuery.HasDelegate)
            await FireQuery();
        else
        {
            Recompute();
            if (OnSearch.HasDelegate)
                await OnSearch.InvokeAsync(string.Empty);
        }
    }

    // ════════════════════════════════════════════════════════════
    //  CLIENT-SIDE PIPELINE: filter → sort → paginate
    // ════════════════════════════════════════════════════════════

    void Recompute()
    {
        if (ServerSide) { UpdateServerSidePaging(); return; }

        _filtered = Rows.Where(row =>
        {
            if (!string.IsNullOrWhiteSpace(_globalSearch))
            {
                var q = _globalSearch.Trim();
                if (!VisibleColumns.Any(col =>
                    row.GetValueOrDefault(col.Key)?.ToString()
                       ?.Contains(q, StringComparison.OrdinalIgnoreCase) == true))
                    return false;
            }
            foreach (var (key, filter) in _colFilters)
            {
                if (string.IsNullOrWhiteSpace(filter)) continue;
                var val = row.GetValueOrDefault(key)?.ToString() ?? string.Empty;
                if (!val.Contains(filter, StringComparison.OrdinalIgnoreCase)) return false;
            }
            return true;
        }).ToList();

        if (SortKey is not null)
        {
            _filtered = SortAsc
                ? _filtered.OrderBy(r => r.GetValueOrDefault(SortKey)?.ToString(), StringComparer.OrdinalIgnoreCase).ToList()
                : _filtered.OrderByDescending(r => r.GetValueOrDefault(SortKey)?.ToString(), StringComparer.OrdinalIgnoreCase).ToList();
        }

        _totalPages = Math.Max(1, (int)Math.Ceiling(_filtered.Count / (double)_pageSize));
        if (_pageIndex >= _totalPages) _pageIndex = 0;
        _paged = _filtered.Skip(_pageIndex * _pageSize).Take(_pageSize).ToList();
    }

    // ════════════════════════════════════════════════════════════
    //  CSS HELPERS
    // ════════════════════════════════════════════════════════════

    string ColWidth(GridColumn col)    => col.Width    ?? "1fr";
    string ColMinWidth(GridColumn col) => col.MinWidth ?? "80px";

    IEnumerable<int> PageNumbers
    {
        get
        {
            var start = Math.Max(0, _pageIndex - 2);
            var end   = Math.Min(_totalPages - 1, start + 4);
            start     = Math.Max(0, end - 4);
            return Enumerable.Range(start, end - start + 1);
        }
    }

    string GridTemplate
    {
        get
        {
            var parts = new List<string>();
            if (ShowRowNumbers) parts.Add("48px");
            parts.AddRange(VisibleColumns.Select(c => c.Width ?? "1fr"));
            if (HasRowActions) parts.Add("auto");
            return string.Join(" ", parts);
        }
    }


}

