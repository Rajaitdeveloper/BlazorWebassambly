@* Shared/Components/DataGrid.razor *@
@* Self-contained reusable data grid.
   Models (GridColumn, CellContext) are defined in the @code block — no external model files needed.
   
   USAGE:
   ──────
   var columns = new List<GridColumn>
   {
       new() { Key = "name",   Label = "Full Name",  Width = "200px", Sortable = true, Filterable = true },
       new() { Key = "email",  Label = "Email",      Width = "1fr",   Sortable = true, Filterable = true },
       new() { Key = "role",   Label = "Role",       Width = "120px", Sortable = true },
       new() { Key = "status", Label = "Status",     Width = "100px", Filterable = true },
   };

   var rows = new List<Dictionary<string, object?>>
   {
       new() { ["name"] = "Raja T", ["email"] = "raja@corp.com", ["role"] = "Admin", ["status"] = "Active" },
   };

   <DataGrid Columns="columns" Rows="rows" PageSize="10" ShowRowNumbers="true">
       <CellTemplate Context="cell">
           @if (cell.Column.Key == "status")
           {
               <span class="my-badge">@cell.Value</span>
           }
           else { @cell.Value }
       </CellTemplate>
   </DataGrid>
*@

@* ── Toolbar ── *@
<div class="dg-wrap">

    <div class="dg-toolbar">
        <div class="dg-search-wrap">
            <i class="fa-solid fa-magnifying-glass dg-search-icon"></i>
            <input class="dg-search @(EnableSearchButton ? "dg-search-has-btn" : "")"
                   type="search"
                   placeholder="Search all columns…"
                   @bind="_searchInput"
                   @bind:event="@(EnableSearchButton ? "onchange" : "oninput")"
                   @onkeydown="OnSearchKeyDown" />
            @if (!string.IsNullOrEmpty(_searchInput))
            {
                <button class="dg-search-clear @(EnableSearchButton ? "dg-search-clear-with-btn" : "")"
                        @onclick="ClearSearch" title="Clear">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            }
            @if (EnableSearchButton)
            {
                <button class="dg-search-btn" @onclick="ApplySearch" title="Search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <span>Search</span>
                </button>
            }
        </div>
        <div class="dg-toolbar-right">
            <span class="dg-count">@_filtered.Count of @Rows.Count row@(Rows.Count != 1 ? "s" : "")</span>
            @if (_filtered.Count != Rows.Count || !string.IsNullOrEmpty(_searchInput))
            {
                <button class="dg-btn-ghost" @onclick="ClearAll">
                    <i class="fa-solid fa-filter-circle-xmark"></i> Clear filters
                </button>
            }
        </div>
    </div>

    @* ── Column filters ── *@
    @if (Columns.Any(c => c.Filterable))
    {
        <div class="dg-filters">
            @if (ShowRowNumbers) { <div class="dg-filter-cell dg-rn-cell"></div> }
            @foreach (var col in VisibleColumns)
            {
                <div class="dg-filter-cell" style="width:@ColWidth(col); min-width:@ColMinWidth(col)">
                    @if (col.Filterable)
                    {
                        <input class="dg-col-filter"
                               type="search"
                               placeholder="@col.Label…"
                               value="@GetColFilter(col.Key)"
                               @oninput="e => SetColFilter(col.Key, e.Value?.ToString())" />
                    }
                </div>
            }
        </div>
    }

    @* ── Desktop table ── *@
    <div class="dg-table-wrap @(ShowScrollbar ? "dg-scrollable" : "")" style="@(ShowScrollbar ? $"max-height:{ScrollHeight}" : "")">
        <div class="dg-table" style="grid-template-columns: @GridTemplate">

            @* Header row *@
            @if (ShowRowNumbers)
            {
                <div class="dg-th dg-rn-cell">#</div>
            }
            @foreach (var col in VisibleColumns)
            {
                <div class="dg-th @(col.Sortable ? "dg-th-sort" : "") @(SortKey == col.Key ? "dg-th-active" : "")"
                     @onclick="() => ToggleSort(col)">
                    <span class="dg-th-label">@col.Label</span>
                    @if (col.Sortable)
                    {
                        <span class="dg-sort-icon">
                            @if (SortKey == col.Key)
                            {
                                <i class="fa-solid @(SortAsc ? "fa-sort-up" : "fa-sort-down")"></i>
                            }
                            else
                            {
                                <i class="fa-solid fa-sort dg-sort-idle"></i>
                            }
                        </span>
                    }
                </div>
            }
            @if (HasRowActions)
            {
                <div class="dg-th dg-th-actions">@RowActionsLabel</div>
            }

            @* Data rows *@
            @if (!_paged.Any())
            {
                <div class="dg-empty" style="grid-column: 1 / -1">
                    <i class="fa-solid fa-inbox"></i>
                    <span>No results found</span>
                </div>
            }
            else
            {
                @foreach (var (row, idx) in _paged.Select((r, i) => (r, i)))
                {
                    @if (ShowRowNumbers)
                    {
                        <div class="dg-td dg-rn-cell @(idx % 2 == 1 ? "dg-row-alt" : "")" data-row="@idx">
                            @(_pageIndex * _pageSize + idx + 1)
                        </div>
                    }
                    @foreach (var col in VisibleColumns)
                    {
                        <div class="dg-td @(idx % 2 == 1 ? "dg-row-alt" : "")" data-row="@idx" data-label="@col.Label">
                            @if (CellTemplate is not null)
                            {
                                @CellTemplate(new CellContext { Column = col, Row = row, Value = row.GetValueOrDefault(col.Key) })
                            }
                            else
                            {
                                @row.GetValueOrDefault(col.Key)
                            }
                        </div>
                    }
                    @if (HasRowActions)
                    {
                        <div class="dg-td dg-td-actions @(idx % 2 == 1 ? "dg-row-alt" : "")" data-row="@idx">
                            @if (OnView.HasDelegate)
                            {
                                <button class="dg-action-btn dg-action-view"
                                        @onclick="() => OnView.InvokeAsync(new RowActionContext { Row = row })"
                                        title="View">
                                    <i class="fa-solid fa-eye"></i>
                                    <span>View</span>
                                </button>
                            }
                            @if (OnEdit.HasDelegate)
                            {
                                <button class="dg-action-btn dg-action-edit"
                                        @onclick="() => OnEdit.InvokeAsync(new RowActionContext { Row = row })"
                                        title="Edit">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                    <span>Edit</span>
                                </button>
                            }
                        </div>
                    }
                }
            }
        </div>
    </div>

    @* ── Mobile cards ── *@
    <div class="dg-cards">
        @if (!_paged.Any())
        {
            <div class="dg-empty dg-empty-card">
                <i class="fa-solid fa-inbox"></i>
                <span>No results found</span>
            </div>
        }
        else
        {
            @foreach (var (row, idx) in _paged.Select((r, i) => (r, i)))
            {
                <div class="dg-card">
                    @if (ShowRowNumbers)
                    {
                        <div class="dg-card-num">#@(_pageIndex * _pageSize + idx + 1)</div>
                    }
                    @foreach (var col in VisibleColumns)
                    {
                        <div class="dg-card-row">
                            <span class="dg-card-label">@col.Label</span>
                            <span class="dg-card-val">
                                @if (CellTemplate is not null)
                                {
                                    @CellTemplate(new CellContext { Column = col, Row = row, Value = row.GetValueOrDefault(col.Key) })
                                }
                                else
                                {
                                    @row.GetValueOrDefault(col.Key)
                                }
                            </span>
                        </div>
                    }
                    @if (HasRowActions)
                    {
                        <div class="dg-card-actions">
                            @if (OnView.HasDelegate)
                            {
                                <button class="dg-action-btn dg-action-view"
                                        @onclick="() => OnView.InvokeAsync(new RowActionContext { Row = row })"
                                        title="View">
                                    <i class="fa-solid fa-eye"></i>
                                    <span>View</span>
                                </button>
                            }
                            @if (OnEdit.HasDelegate)
                            {
                                <button class="dg-action-btn dg-action-edit"
                                        @onclick="() => OnEdit.InvokeAsync(new RowActionContext { Row = row })"
                                        title="Edit">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                    <span>Edit</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>

    @* ── Pagination ── *@
    @if (_totalPages > 1)
    {
        <div class="dg-pagination">
            <span class="dg-page-info">Page @(_pageIndex + 1) of @_totalPages</span>
            <div class="dg-page-btns">
                <button class="dg-page-btn" @onclick="FirstPage" disabled="@(_pageIndex == 0)" title="First">
                    <i class="fa-solid fa-angles-left"></i>
                </button>
                <button class="dg-page-btn" @onclick="PrevPage" disabled="@(_pageIndex == 0)" title="Previous">
                    <i class="fa-solid fa-angle-left"></i>
                </button>
                @foreach (var p in PageNumbers)
                {
                    <button class="dg-page-btn @(p == _pageIndex ? "dg-page-active" : "")"
                            @onclick="() => GoToPage(p)">@(p + 1)</button>
                }
                <button class="dg-page-btn" @onclick="NextPage" disabled="@(_pageIndex >= _totalPages - 1)" title="Next">
                    <i class="fa-solid fa-angle-right"></i>
                </button>
                <button class="dg-page-btn" @onclick="LastPage" disabled="@(_pageIndex >= _totalPages - 1)" title="Last">
                    <i class="fa-solid fa-angles-right"></i>
                </button>
            </div>
            <select class="dg-page-size" @bind="_pageSize" @bind:after="ResetPage">
                <option value="5">5 / page</option>
                <option value="10">10 / page</option>
                <option value="25">25 / page</option>
                <option value="50">50 / page</option>
            </select>
        </div>
    }

</div>

@code {

    // ════════════════════════════════════════════════════════════
    //  MODELS — defined here so no external file is needed
    // ════════════════════════════════════════════════════════════

    /// <summary>
    /// Defines a single column in the DataGrid.
    /// Width accepts any CSS grid track value: "1fr", "200px", "minmax(120px,1fr)" etc.
    /// </summary>
    public sealed class GridColumn
    {
        /// <summary>Key matching the row dictionary entry.</summary>
        public required string Key { get; init; }

        /// <summary>Header label shown in the grid.</summary>
        public required string Label { get; init; }

        /// <summary>
        /// CSS grid column width. Examples:
        ///   "1fr"              — flexible, fills available space (default)
        ///   "200px"            — fixed pixel width
        ///   "20%"              — percentage
        ///   "minmax(120px,1fr)"— responsive range
        /// </summary>
        public string? Width { get; init; } = "1fr";

        /// <summary>Minimum width before horizontal scroll kicks in. Default "80px".</summary>
        public string? MinWidth { get; init; } = "80px";

        /// <summary>Enable click-to-sort on this column header.</summary>
        public bool Sortable { get; init; } = false;

        /// <summary>Show a per-column filter input below the header.</summary>
        public bool Filterable { get; init; } = false;

        /// <summary>
        /// Hide this column from the rendered table and mobile cards.
        /// The value is still present in the row dictionary — use it
        /// to pass hidden IDs to OnView / OnEdit callbacks.
        /// Example: new GridColumn { Key = "id", Label = "ID", Hidden = true }
        /// </summary>
        public bool Hidden { get; init; } = false;
    }

    /// <summary>
    /// Passed to the CellTemplate render fragment.
    /// Gives access to the column definition, full row, and the cell value.
    /// </summary>
    public sealed class CellContext
    {
        public required GridColumn               Column { get; init; }
        public required Dictionary<string, object?> Row { get; init; }
        public object?                            Value { get; init; }
    }

    /// <summary>
    /// Context passed to OnView and OnEdit callbacks.
    /// Contains the full row dictionary so hidden ID columns are accessible.
    /// </summary>
    public sealed class RowActionContext
    {
        /// <summary>The full row data including hidden columns.</summary>
        public required Dictionary<string, object?> Row { get; init; }

        /// <summary>Shortcut to read a value by column key.</summary>
        public object? Get(string key) => Row.GetValueOrDefault(key);

        /// <summary>Shortcut to read a typed value by column key.</summary>
        public T? Get<T>(string key) =>
            Row.TryGetValue(key, out var v) && v is T typed ? typed : default;
    }

    // ════════════════════════════════════════════════════════════
    //  PARAMETERS
    // ════════════════════════════════════════════════════════════

    /// <summary>Column definitions.</summary>
    [Parameter, EditorRequired]
    public List<GridColumn> Columns { get; set; } = [];

    /// <summary>Row data — each row is a Dictionary keyed by GridColumn.Key.</summary>
    [Parameter, EditorRequired]
    public List<Dictionary<string, object?>> Rows { get; set; } = [];

    /// <summary>Rows per page. Default 10.</summary>
    [Parameter] public int PageSize { get; set; } = 10;

    /// <summary>Show a leading row-number column.</summary>
    [Parameter] public bool ShowRowNumbers { get; set; } = false;

    /// <summary>
    /// Optional custom cell renderer.
    /// Receives a CellContext with Column, Row, and Value.
    /// Omit to render the value as plain text.
    /// </summary>
    [Parameter] public RenderFragment<CellContext>? CellTemplate { get; set; }

    /// <summary>
    /// Show a vertical scrollbar inside the table body.
    /// When true, the table body is constrained to ScrollHeight and scrolls vertically.
    /// Default false — table grows with content.
    /// </summary>
    [Parameter] public bool ShowScrollbar { get; set; } = false;

    /// <summary>
    /// Maximum height of the scrollable table body when ShowScrollbar is true.
    /// Accepts any CSS height value: "400px", "60vh", "300px" etc.
    /// Default "400px".
    /// </summary>
    [Parameter] public string ScrollHeight { get; set; } = "400px";

    /// <summary>
    /// When true, search only fires when the Search button is clicked or Enter is pressed.
    /// Use this when rows are loaded from an API to avoid a request on every keystroke.
    /// When false (default), search filters instantly on each keystroke.
    /// </summary>
    [Parameter] public bool EnableSearchButton { get; set; } = false;

    /// <summary>
    /// Callback fired when a search is triggered (button click or Enter).
    /// Only raised when EnableSearchButton is true.
    /// Receives the current search term — use it to call your API.
    /// </summary>
    [Parameter] public EventCallback<string> OnSearch { get; set; }

    /// <summary>
    /// When set, a View button appears in the Actions column for each row.
    /// Receives a RowActionContext — access hidden ID columns via context.Get("id").
    /// </summary>
    [Parameter] public EventCallback<RowActionContext> OnView { get; set; }

    /// <summary>
    /// When set, an Edit button appears in the Actions column for each row.
    /// Receives a RowActionContext — access hidden ID columns via context.Get("id").
    /// </summary>
    [Parameter] public EventCallback<RowActionContext> OnEdit { get; set; }

    /// <summary>
    /// Header label for the Actions column. Default "Actions".
    /// </summary>
    [Parameter] public string RowActionsLabel { get; set; } = "Actions";

    /// <summary>Convenience: true when at least one row action is configured.</summary>
    bool HasRowActions => OnView.HasDelegate || OnEdit.HasDelegate;

    /// <summary>Visible columns only (Hidden = false).</summary>
    IEnumerable<GridColumn> VisibleColumns => Columns.Where(c => !c.Hidden);

    // ════════════════════════════════════════════════════════════
    //  INTERNAL STATE
    // ════════════════════════════════════════════════════════════

    string  _globalSearch = string.Empty;  // committed search term used in filter pipeline
    string  _searchInput  = string.Empty;  // live value bound to the input (pending when button mode)
    string? SortKey;
    bool    SortAsc    = true;
    int     _pageIndex = 0;
    int     _pageSize  = 10;

    readonly Dictionary<string, string> _colFilters = new();

    List<Dictionary<string, object?>> _filtered = [];
    List<Dictionary<string, object?>> _paged    = [];
    int _totalPages = 1;

    protected override void OnParametersSet()
    {
        _pageSize = PageSize;
        Recompute();
    }

    // ── Search button helpers ─────────────────────────────────────────────────

    /// <summary>Commit the search input and fire OnSearch callback (API mode).</summary>
    async Task ApplySearch()
    {
        _globalSearch = _searchInput;
        _pageIndex    = 0;
        Recompute();
        if (OnSearch.HasDelegate)
            await OnSearch.InvokeAsync(_globalSearch);
    }

    /// <summary>Allow pressing Enter in the search box to trigger search.</summary>
    async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (!EnableSearchButton) return;
        if (e.Key == "Enter") await ApplySearch();
    }

    /// <summary>Clear both the input and the committed search term.</summary>
    async Task ClearSearch()
    {
        _searchInput  = string.Empty;
        _globalSearch = string.Empty;
        _pageIndex    = 0;
        Recompute();
        if (EnableSearchButton && OnSearch.HasDelegate)
            await OnSearch.InvokeAsync(string.Empty);
    }

    // ════════════════════════════════════════════════════════════
    //  PIPELINE: filter → sort → paginate
    // ════════════════════════════════════════════════════════════

    void Recompute()
    {
        // 1. Filter
        _filtered = Rows.Where(row =>
        {
            if (!string.IsNullOrWhiteSpace(_globalSearch))
            {
                var q     = _globalSearch.Trim();
                var match = Columns.Any(col =>
                    row.GetValueOrDefault(col.Key)?.ToString()
                       ?.Contains(q, StringComparison.OrdinalIgnoreCase) == true);
                if (!match) return false;
            }
            foreach (var (key, filter) in _colFilters)
            {
                if (string.IsNullOrWhiteSpace(filter)) continue;
                var val = row.GetValueOrDefault(key)?.ToString() ?? string.Empty;
                if (!val.Contains(filter, StringComparison.OrdinalIgnoreCase)) return false;
            }
            return true;
        }).ToList();

        // 2. Sort
        if (SortKey is not null)
        {
            _filtered = SortAsc
                ? _filtered.OrderBy(r => r.GetValueOrDefault(SortKey)?.ToString(), StringComparer.OrdinalIgnoreCase).ToList()
                : _filtered.OrderByDescending(r => r.GetValueOrDefault(SortKey)?.ToString(), StringComparer.OrdinalIgnoreCase).ToList();
        }

        // 3. Paginate
        _totalPages = Math.Max(1, (int)Math.Ceiling(_filtered.Count / (double)_pageSize));
        if (_pageIndex >= _totalPages) _pageIndex = 0;
        _paged = _filtered.Skip(_pageIndex * _pageSize).Take(_pageSize).ToList();
    }

    // ════════════════════════════════════════════════════════════
    //  SORT
    // ════════════════════════════════════════════════════════════

    void ToggleSort(GridColumn col)
    {
        if (!col.Sortable) return;
        if (SortKey == col.Key) SortAsc = !SortAsc;
        else { SortKey = col.Key; SortAsc = true; }
        _pageIndex = 0;
        Recompute();
    }

    // ════════════════════════════════════════════════════════════
    //  FILTERS
    // ════════════════════════════════════════════════════════════

    string GetColFilter(string key) =>
        _colFilters.TryGetValue(key, out var v) ? v : string.Empty;

    void SetColFilter(string key, string? value)
    {
        if (string.IsNullOrEmpty(value)) _colFilters.Remove(key);
        else _colFilters[key] = value;
        _pageIndex = 0;
        Recompute();
    }

    void ClearAll()
    {
        _searchInput  = string.Empty;
        _globalSearch = string.Empty;
        _colFilters.Clear();
        SortKey    = null;
        SortAsc    = true;
        _pageIndex = 0;
        Recompute();
    }

    // ════════════════════════════════════════════════════════════
    //  PAGINATION
    // ════════════════════════════════════════════════════════════

    void FirstPage()     { _pageIndex = 0;               Recompute(); }
    void PrevPage()      { _pageIndex--;                  Recompute(); }
    void NextPage()      { _pageIndex++;                  Recompute(); }
    void LastPage()      { _pageIndex = _totalPages - 1;  Recompute(); }
    void GoToPage(int p) { _pageIndex = p;                Recompute(); }
    void ResetPage()     { _pageIndex = 0;                Recompute(); }

    IEnumerable<int> PageNumbers
    {
        get
        {
            var start = Math.Max(0, _pageIndex - 2);
            var end   = Math.Min(_totalPages - 1, start + 4);
            start     = Math.Max(0, end - 4);
            return Enumerable.Range(start, end - start + 1);
        }
    }

    // ════════════════════════════════════════════════════════════
    //  CSS HELPERS
    // ════════════════════════════════════════════════════════════

    string ColWidth(GridColumn col)    => col.Width    ?? "1fr";
    string ColMinWidth(GridColumn col) => col.MinWidth ?? "80px";

    string GridTemplate
    {
        get
        {
            var parts = new List<string>();
            if (ShowRowNumbers) parts.Add("48px");
            parts.AddRange(VisibleColumns.Select(c => c.Width ?? "1fr"));
            if (HasRowActions) parts.Add("auto");
            return string.Join(" ", parts);
        }
    }
}

<style>
    /* ══════════════════════════════════════
       DataGrid — all styles scoped here
    ══════════════════════════════════════ */

    .dg-wrap {
        display: flex; flex-direction: column;
        background: var(--surface, #fff);
        border: 1px solid var(--border, #e2e8f0);
        border-radius: var(--radius-lg, 14px);
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
        font-family: var(--font, 'Plus Jakarta Sans', system-ui, sans-serif);
        font-size: 13px;
    }

    /* ── Toolbar ── */
    .dg-toolbar {
        display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
        padding: 14px 16px;
        border-bottom: 1px solid var(--border, #e2e8f0);
        background: var(--surface-2, #f7f9fc);
    }
    .dg-search-wrap { position: relative; flex: 1; min-width: 180px; max-width: 340px; }
    .dg-search-icon {
        position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
        color: var(--txt-3, #94a3b8); font-size: 12px; pointer-events: none;
    }
    .dg-search {
        width: 100%; padding: 7px 32px 7px 32px;
        border: 1px solid var(--border, #e2e8f0);
        border-radius: var(--radius, 8px);
        background: var(--surface, #fff);
        font-size: 13px; color: var(--txt, #1e293b);
        font-family: var(--font, inherit); outline: none;
        transition: border-color .15s, box-shadow .15s;
    }
    .dg-search:focus {
        border-color: var(--accent, #c81766);
        box-shadow: 0 0 0 3px var(--accent-faint, rgba(200,23,102,.12));
    }
    .dg-search-clear {
        position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
        background: none; border: none; cursor: pointer; padding: 2px 4px;
        color: var(--txt-3, #94a3b8); font-size: 11px; border-radius: 4px;
        transition: color .12s;
    }
    .dg-search-clear:hover { color: var(--txt, #1e293b); }

    /* Search button mode — extra right padding for button */
    .dg-search-has-btn { padding-right: 96px; }
    .dg-search-clear-with-btn { right: 76px; }

    .dg-search-btn {
        position: absolute; right: 0; top: 0; bottom: 0;
        display: inline-flex; align-items: center; gap: 6px;
        padding: 0 14px;
        background: var(--accent, #c81766); color: #fff;
        border: none; border-radius: 0 var(--radius, 8px) var(--radius, 8px) 0;
        font-size: 12px; font-weight: 700; cursor: pointer;
        font-family: var(--font, inherit); white-space: nowrap;
        transition: background .15s;
    }
    .dg-search-btn:hover { background: var(--accent-hover, #a81257); }
    .dg-search-btn i { font-size: 11px; }
    .dg-toolbar-right { display: flex; align-items: center; gap: 10px; margin-left: auto; }
    .dg-count { font-size: 12px; color: var(--txt-3, #94a3b8); white-space: nowrap; }
    .dg-btn-ghost {
        display: inline-flex; align-items: center; gap: 6px;
        background: none; border: 1px solid var(--border, #e2e8f0);
